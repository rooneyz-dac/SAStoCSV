1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : variable_info_cli20260320.sas
3          | SHORT DESC   : Creates a variable information document with CLI
4          |                parameter support
5          *------------------------------------------------------------------*
6          | CREATED BY   : Modified for CLI usage
7          | DATE CREATED : 2025-01-22
8          *------------------------------------------------------------------*
9          | VERSION UPDATES:
10         | 2025-01-22: Initial CLI release
11         |   - Added SYSPARM parsing for input and output directories
12         |   - Added automatic creation of DAC_Documents output subfolder
13         |   - Added path validation for input and output directories
14         |   - Output file name includes library name and date stamp
15         |   - Each dataset is placed on its own sheet in the Excel workbook
16         *------------------------------------------------------------------*
17         | PURPOSE
18         | Creates a variable-level information report for all datasets in a
19         | designated directory. For each dataset the report lists variable
20         | number, name, type, length, format, informat, and label. Results
21         | are exported to a multi-sheet Excel workbook (.xlsx) in the
22         | DAC_Documents subfolder of the output directory, with one sheet
23         | per dataset.
24         |
25         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
26         | INPUT_DIRECTORY  = Path to the folder containing SAS datasets
27         |                    (.sas7bdat) to be summarized
28         | OUTPUT_DIRECTORY = Path to the folder where the DAC_Documents
29         |                    subfolder and output file will be created.
30         |                    Must exist prior to execution.
31         |
32         | 2.0: OPTIONAL PARAMETERS
2                                           The SAS System                16:55 Friday, March 20, 2026

33         | None. All parameters are supplied via SYSPARM.
34         |
35         | USAGE:
36         |   sas -sysparm "input_directory|output_directory"
37         |       -sysin variable_info_cli20260320.sas
38         |
39         | OUTPUT STRUCTURE:
40         |   output_directory\
41         |   └── DAC_Documents\
42         |       └── variable_info_<libname>_<YYYYMMDD>.xlsx
43         |           (one Excel sheet per dataset)
44         *------------------------------------------------------------------*
45         | OPERATING SYSTEM COMPATIBILITY
46         | SAS v9.4 or Higher: Yes
47         *------------------------------------------------------------------*
48         | MACRO CALL
49         |
50         | Not applicable. Script is invoked directly via the SAS command
51         | line using -sysin and -sysparm.
52         *------------------------------------------------------------------*
53         | EXAMPLES
54         |
55         | Basic usage:
56         |   sas -sysparm "C:\data\input|C:\data\output"
57         |       -sysin variable_info_cli20260320.sas
58         |
59         | Using a study-specific directory:
60         |   sas -sysparm "C:\studies\trial1\sas|C:\studies\trial1\output"
61         |       -sysin variable_info_cli20260320.sas
62         *------------------------------------------------------------------*/
63         
64         %macro variable_info_cli;
65             /**Parse SYSPARM for input and output paths**/
66             %local sysparm_value indir outdir pipe_pos;
67             %let sysparm_value = &sysparm;
68             %put DEBUG: Raw SYSPARM value = &sysparm_value;
69         
70             %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
71             %put DEBUG: Pipe position = &pipe_pos;
72         
73             %if &pipe_pos > 0 %then %do;
74                 %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
75                 %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
76             %end;
77             %else %do;
78                 %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
79                 %abort;
80             %end;
81         
82             %put DEBUG: Input Directory = &indir;
83             %put DEBUG: Output Directory = &outdir;
84         
85             /**Validate directories exist**/
86             %local indir_exist outdir_exist;
3                                           The SAS System                16:55 Friday, March 20, 2026

87             %let indir_exist = %sysfunc(fileexist(&indir));
88             %let outdir_exist = %sysfunc(fileexist(&outdir));
89         
90             %put DEBUG: Input directory exists = &indir_exist;
91             %put DEBUG: Output directory exists = &outdir_exist;
92         
93             %if &indir_exist = 0 %then %do;
94                 %put ERROR: Input directory does not exist: &indir;
95                 %abort;
96             %end;
97         
98             %if &outdir_exist = 0 %then %do;
99                 %put ERROR: Output directory does not exist: &outdir;
100                %abort;
101            %end;
102        
103            /**Create DAC_Documents folder if it doesn't exist**/
104            %local doc_dir doc_exist rc;
105            %let doc_dir = &outdir\DAC_Documents;
106            %let doc_exist = %sysfunc(fileexist(&doc_dir));
107        
108            %if &doc_exist = 0 %then %do;
109                %put DEBUG: Creating directory &doc_dir;
110                %let rc = %sysfunc(dcreate(DAC_Documents, &outdir));
111                %if &rc = %then %do;
112                    %put ERROR: Failed to create directory &doc_dir;
113                    %abort;
114                %end;
115                %put DEBUG: Successfully created &doc_dir;
116            %end;
117            %else %do;
118                %put DEBUG: Directory &doc_dir already exists;
119            %end;
120        
121            /**Assign library to input directory**/
122            libname INLIB "&indir";
123        
124            %if %sysfunc(libref(INLIB)) ^= 0 %then %do;
125                %put ERROR: Failed to assign library to &indir;
126                %abort;
127            %end;
128        
129            /**Set output file path**/
130            %local out_file libname_text;
131            %let libname_text = %scan(&indir, -1, \);
132            %if %sysevalf(%superq(libname_text)=,boolean) %then %let libname_text = INPUT;
133            %let out_file =
133      ! &doc_dir\variable_info_%sysfunc(compress(&libname_text,,'ka'))_%sysfunc(today(),yymmddn8.).
133      ! xlsx;
134            %put DEBUG: Output file = &out_file;
135        
136            /**Get variable information**/
137            ods output variables=allvarout;
138        
4                                           The SAS System                16:55 Friday, March 20, 2026

139            proc contents data=INLIB._all_ memtype=data;
140            run;
141        
142            /**Sort data by dataset and variable number**/
143            proc sort data=allvarout;
144                by member num;
145            run;
146        
147            /**Create Excel output file with separate sheets per dataset**/
148            options nobyline;
149            ods excel file="&out_file"
150                options(sheet_name="#BYVAL(member)" embedded_titles='yes');
151        
152            proc print data=allvarout noobs label;
153                by member;
154                pageby member;
155                title "Variables in #BYVAL(member) Dataset";
156                label member='Dataset Name'
157                      num='Variable Number'
158                      variable='Variable Name'
159                      type='Type'
160                      len='Length'
161                      format='Format'
162                      informat='Informat'
163                      label='Variable Label';
164            run;
165        
166            title;
167        
168            ods excel close;
169        
170            /**Clean up**/
171            proc datasets library=work nolist nodetails;
172                delete allvarout;
173            quit;
174        
175            libname INLIB clear;
176        
177            %put NOTE: Variable information document created: &out_file;
178        
179        %mend variable_info_cli;
180        
181        %variable_info_cli;
