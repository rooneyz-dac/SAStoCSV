1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoXPTcli20260320.sas
3          | SHORT DESC   : Bidirectional batch conversion between SAS7BDAT
4          |                and XPT (SAS Transport) formats via CLI
5          *------------------------------------------------------------------*
6          | CREATED BY   : Modified for CLI usage
7          | DATE CREATED : 2025-11-21
8          | VERSION      : 2.0
9          *------------------------------------------------------------------*
10         | VERSION UPDATES:
11         | 2025-11-21: Initial CLI release
12         |   - Added SYSPARM parsing for input and output directories
13         |   - Added bidirectional conversion (SAS7BDAT <-> XPT)
14         |   - Added automatic creation of DAC_XPT and DAC_SDTM subfolders
15         |   - Added conversion error log generation
16         *------------------------------------------------------------------*
17         | PURPOSE
18         | Performs batch bidirectional conversion of SAS datasets between
19         | SAS7BDAT and XPT (SAS Transport) formats. When .sas7bdat files
20         | are detected in the input directory they are converted to .xpt
21         | and placed in OUTDIR\DAC_XPT. When .xpt files are detected they
22         | are converted to .sas7bdat and placed in OUTDIR\DAC_SDTM. Both
23         | conversion types may occur in a single run. An error log
24         | (xpt_error_log.txt) is written to the output directory.
25         |
26         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
27         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
28         |                    files to be converted
29         | OUTPUT_DIRECTORY = Path to folder where output subfolders and
30         |                    the error log will be created. Must exist
31         |                    prior to execution.
32         |
2                                           The SAS System              16:21 Thursday, March 26, 2026

33         | 2.0: XPT FORMAT LIMITATIONS
34         | MEMBER NAMES     = Limited to 8 characters by the XPT format
35         |                    specification. Dataset names longer than 8
36         |                    characters are automatically truncated to the
37         |                    first 4 characters concatenated with the last
38         |                    4 characters.
39         |                    Example: "berkeley_pbo_ae" becomes "berkl_ae"
40         |
41         | USAGE:
42         |   sas -sysparm "input_directory|output_directory"
43         |       -sysin SAStoXPTcli20260320.sas
44         |
45         | OUTPUT STRUCTURE:
46         |   output_directory\
47         |   ├── DAC_XPT\          - XPT exports (from .sas7bdat input)
48         |   ├── DAC_SDTM\         - SAS7BDAT exports (from .xpt input)
49         |   └── xpt_error_log.txt - Conversion activity and error log
50         *------------------------------------------------------------------*
51         | OPERATING SYSTEM COMPATIBILITY
52         | SAS v9.4 or Higher: Yes
53         | Windows:            Yes (uses DIR command for file listing)
54         *------------------------------------------------------------------*
55         | MACRO CALL
56         |
57         | Not applicable. Script is invoked directly via the SAS command
58         | line using -sysin and -sysparm.
59         *------------------------------------------------------------------*
60         | EXAMPLES
61         |
62         | Convert SAS datasets to XPT format:
63         |   sas -sysparm "C:\data\input|C:\data\output"
64         |       -sysin SAStoXPTcli20260320.sas
65         |
66         | Convert XPT files back to SAS7BDAT:
67         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
68         |       -sysin SAStoXPTcli20260320.sas
69         |
70         | Process a mixed directory (both .sas7bdat and .xpt present):
71         |   sas -sysparm "C:\data\mixed|C:\data\output"
72         |       -sysin SAStoXPTcli20260320.sas
73         *------------------------------------------------------------------*/
74         
75         %macro convert_files;
76             %let sysparm_value = &sysparm;
77             %put DEBUG: Raw SYSPARM value = &sysparm_value;
78         
79             %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
80             %put DEBUG: Pipe position = &pipe_pos;
81         
82             %if &pipe_pos > 0 %then %do;
83                 %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
84                 %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
85             %end;
86             %else %do;
3                                           The SAS System              16:21 Thursday, March 26, 2026

87                 %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
88                 %abort;
89             %end;
90         
91             %put DEBUG: Input Directory = &indir;
92             %put DEBUG: Output Directory = &outdir;
93         
94             %let indir_exist = %sysfunc(fileexist(&indir));
95             %let outdir_exist = %sysfunc(fileexist(&outdir));
96         
97             %if &indir_exist = 0 %then %do;
98                 %put ERROR: Input directory does not exist: &indir;
99                 %abort;
100            %end;
101        
102            %if &outdir_exist = 0 %then %do;
103                %put ERROR: Output directory does not exist: &outdir;
104                %abort;
105            %end;
106        
107            %let errlog = &outdir\xpt_error_log.txt;
108        
109            data _null_;
110                file "&errlog";
111                length dt $19;
112                dt = put(datetime(), datetime19.);
113                put "Error Log - " dt;
114                put "Input Directory: &indir";
115                put "Output Directory: &outdir";
116                put "----------------------------------------";
117            run;
118        
119            filename infiles pipe "dir /b ""&indir\*.sas7bdat"" ""&indir\*.xpt"" 2>nul";
120        
121            data file_list;
122                infile infiles truncover;
123                input filename $256.;
124                length filetype $10;
125                if index(upcase(filename), '.SAS7BDAT') > 0 then filetype = 'SAS7BDAT';
126                else if index(upcase(filename), '.XPT') > 0 then filetype = 'XPT';
127            run;
128        
129            filename infiles clear;
130        
131            proc sql noprint;
132                select count(*) into :sas7bdat_count trimmed from file_list where filetype =
132      ! 'SAS7BDAT';
133                select count(*) into :xpt_count trimmed from file_list where filetype = 'XPT';
134            quit;
135        
136            %put DEBUG: Found &sas7bdat_count SAS7BDAT files;
137            %put DEBUG: Found &xpt_count XPT files;
138        
139            %if &sas7bdat_count > 0 %then %do;
4                                           The SAS System              16:21 Thursday, March 26, 2026

140                %let xpt_dir = &outdir\DAC_XPT;
141                %let xpt_exist = %sysfunc(fileexist(&xpt_dir));
142        
143                %if &xpt_exist = 0 %then %do;
144                    %put DEBUG: Creating directory &xpt_dir;
145                    %let rc = %sysfunc(dcreate(DAC_XPT, &outdir));
146                    %if &rc = %then %do;
147                        %put ERROR: Failed to create directory &xpt_dir;
148                        %abort;
149                    %end;
150                %end;
151        
152                libname inlib "&indir";
153        
154                data _null_;
155                    set file_list end=eof;
156                    where filetype = 'SAS7BDAT';
157        
158                    length dsname memname $32 xpt_path $256;
159        
160                    dsname = scan(filename, 1, '.');
161        
162                    /* Truncate to first 4 + last 4 characters for XPT compliance */
163                    if length(dsname) > 8 then
164                        memname = substr(dsname, 1, 4) || substr(dsname, length(dsname) - 3, 4);
165                    else
166                        memname = dsname;
167        
168                    xpt_path = "&xpt_dir\" || strip(memname) || ".xpt";
169        
170                    call execute('libname xptlib xport "' || strip(xpt_path) || '";');
171        
172                    /* Use PROC DATASETS to rename, then PROC COPY to transfer */
173                    if dsname ne memname then do;
174                        call execute('proc datasets library=inlib nolist; change ' || strip(dsname)
174      !  || '=' || strip(memname) || '; quit;');
175                    end;
176        
177                    call execute('proc copy in=inlib out=xptlib memtype=data; select ' ||
177      ! strip(memname) || '; run;');
178        
179                    /* Rename back if needed */
180                    if dsname ne memname then do;
181                        call execute('proc datasets library=inlib nolist; change ' ||
181      ! strip(memname) || '=' || strip(dsname) || '; quit;');
182                    end;
183        
184                    call execute('libname xptlib clear;');
185        
186                    file "&errlog" mod;
187                    put "Converted to XPT: " dsname " -> " memname " (" xpt_path ")";
188        
189                    if eof then do;
190                        put "----------------------------------------";
5                                           The SAS System              16:21 Thursday, March 26, 2026

191                        put "Total SAS7BDAT files processed: " _n_;
192                    end;
193                run;
194        
195                libname inlib clear;
196            %end;
197        
198            %if &xpt_count > 0 %then %do;
199                %let sdtm_dir = &outdir\DAC_SDTM;
200                %let sdtm_exist = %sysfunc(fileexist(&sdtm_dir));
201        
202                %if &sdtm_exist = 0 %then %do;
203                    %put DEBUG: Creating directory &sdtm_dir;
204                    %let rc = %sysfunc(dcreate(DAC_SDTM, &outdir));
205                    %if &rc = %then %do;
206                        %put ERROR: Failed to create directory &sdtm_dir;
207                        %abort;
208                    %end;
209                %end;
210        
211                libname outsdtm "&sdtm_dir";
212        
213                data _null_;
214                    set file_list end=eof;
215                    where filetype = 'XPT';
216        
217                    length dsname $32;
218        
219                    dsname = scan(filename, 1, '.');
220        
221                    call execute('libname xptlib xport "' || "&indir\" || strip(filename) || '";');
222                    call execute('proc copy in=xptlib out=outsdtm; run;');
223                    call execute('libname xptlib clear;');
224        
225                    file "&errlog" mod;
226                    put "Converted to SAS7BDAT: " dsname;
227        
228                    if eof then do;
229                        put "----------------------------------------";
230                        put "Total XPT files processed: " _n_;
231                    end;
232                run;
233        
234                libname outsdtm clear;
235            %end;
236        
237            %put DEBUG: Conversion process completed;
238        
239            data _null_;
240                file "&errlog" mod;
241                length dt $19;
242                dt = put(datetime(), datetime19.);
243                put "----------------------------------------";
244                put "Process completed: " dt;
6                                           The SAS System              16:21 Thursday, March 26, 2026

245            run;
246        
247        %mend convert_files;
248        
249        %convert_files;
