351            %put NOTE: Found &xpt_total XPT file(s), &xpt_rename_count require renaming.;
352        
353            %if &xpt_total > 0 and &xpt_rename_count > 0 %then %do;
354        
8                                           The SAS System                 12:52 Tuesday, May 19, 2026

355                /* Check for duplicate standard names and warn/exclude */
356                proc sql noprint;
