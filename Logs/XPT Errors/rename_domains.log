1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : rename_study_domains_cli20260320.sas
3          | SHORT DESC   : Standardizes SAS and XPT dataset names by removing
4          |                suffixes (e.g., AE_PLACEBO to AE) and placing
5          |                renamed copies in DAC_<ParentFolderName> or DAC_XPT subfolders
6          *------------------------------------------------------------------*
7          | CREATED BY   : DAC Development Team
8          | DATE CREATED : 2026-05-08
9          | VERSION      : 1.3
10         *------------------------------------------------------------------*
11         | VERSION UPDATES:
12         | 2026-05-08: Initial CLI release (v1.0)
13         |   - Added SYSPARM parsing for input and output directories
14         |   - Standardizes dataset names by keeping only the prefix before
15         |     the first underscore (e.g., AE_PLACEBO -> AE)
16         |   - Copies SAS7BDAT datasets to DAC_SAS subfolder when any file
17         |     in the input directory has a non-standard (suffixed) name
18         |   - Copies XPT datasets to DAC_XPT subfolder when any XPT file
19         |     in the input directory has a non-standard name
20         |   - Files without underscores are copied unchanged to the new
21         |     folder so the folder is a complete, self-consistent set
22         | 2026-05-12: SAS7BDAT logic updated to match OriginalSAS (v1.1)
23         |   - Replaced Windows DIR-based file listing with libname +
24         |     dictionary.tables discovery (aligns with
25         |     rename_study_domains_ZRlocalCopy.sas)
26         |   - ALL datasets are now copied to DAC_SAS first via proc copy,
27         |     then datasets with suffixes are renamed in-place in DAC_SAS
28         |     using proc datasets change (same approach as original script)
29         |   - Standard name derived with scan(memname, 1, '_') -- identical
30         |     to the original script
31         | 2026-05-12: Fix standard name extraction (v1.2)
32         |   - Changed scan position from 1 to -1 so the domain name is taken
2                                           The SAS System                 12:52 Tuesday, May 19, 2026

33         |     from the LAST token after the final underscore (e.g.
34         |     BERKELEY_AE -> AE).  Using position 1 caused all datasets to
35         |     map to the study prefix (e.g. BERKELEY), triggering a duplicate-
36         |     name collision for every dataset in the library.
37         | 2026-05-19: Dynamic SAS output folder naming (v1.3)
38         |   - SAS output folder is now named DAC_<ParentFolderName> where
39         |     ParentFolderName is the leaf segment of the input directory
40         |     (e.g. if input is C:\data\rawdata, folder becomes DAC_rawdata).
41         |   - Handles both Windows backslash and Unix forward slash separators.
42         *------------------------------------------------------------------*
43         | PURPOSE
44         | Checks SAS (.sas7bdat) and XPT (.xpt) datasets in the specified
45         | input directory and standardizes their names by removing
46         | study-specific suffixes (e.g., converting AE_PLACEBO to AE).
47         | When any dataset requires renaming, ALL datasets of that type are
48         | copied with standardized names to a new subfolder:
49         |   - DAC_<ParentFolderName> for .sas7bdat files
50         |   - DAC_XPT for .xpt files
51         | This ensures that subsequent pipeline scripts operate on a
52         | complete, consistently named set of datasets.
53         |
54         | Naming rule: the standard name is the portion of the dataset name
55         | after the last underscore (scan(memname, -1, '_')).  E.g.:
56         |   BERKELEY_AE   -> AE
57         |   BERKELEY_SUPPAE -> SUPPAE
58         |   CM          -> CM  (unchanged; no folder created for this alone)
59         |
60         | 1.1: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
61         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
62         |                    files to be renamed
63         | OUTPUT_DIRECTORY = Path to folder where DAC_<ParentFolderName>
64         |                    and/or DAC_XPT subfolders will be created.
65         |                    Must exist prior to execution.
66         |
67         | USAGE:
68         |   sas -sysparm "input_directory|output_directory"
69         |       -sysin rename_study_domains_cli20260320.sas
70         |
71         | OUTPUT STRUCTURE:
72         |   output_directory\
73         |   ├── DAC_<ParentFolderName>\  - Standardized SAS7BDAT datasets
74         |   │                              (created only when any .sas7bdat
75         |   │                               dataset has a non-standard suffix)
76         |   └── DAC_XPT\   - Standardized XPT datasets
77         |                     (created only when any .xpt file has
78         |                      a non-standard suffix)
79         *------------------------------------------------------------------*
80         | OPERATING SYSTEM COMPATIBILITY
81         | SAS v9.4 or Higher: Yes
82         | Windows:            Yes
83         *------------------------------------------------------------------*
84         | NOTES
85         | - If two input datasets share the same standard name (e.g.,
86         |   AE_PLACEBO and AE_TREATMENT both map to AE), a WARNING is
3                                           The SAS System                 12:52 Tuesday, May 19, 2026

87         |   issued and those datasets are skipped.  Resolve naming conflicts
88         |   in the source data before running the pipeline.
89         | - For XPT files the script queries the SAS transport library to
90         |   obtain the actual member name inside each file.  SAS XPT
91         |   format limits member names to 8 characters.
92         *------------------------------------------------------------------*
93         | EXAMPLES
94         |
95         | Standardize SAS dataset names:
96         |   sas -sysparm "C:\data\input|C:\data\output"
97         |       -sysin rename_study_domains_cli20260320.sas
98         |
99         | Standardize XPT dataset names:
100        |   sas -sysparm "C:\data\xpt_files|C:\data\output"
101        |       -sysin rename_study_domains_cli20260320.sas
102        *------------------------------------------------------------------*/
103        
104        /* ----------------------------------------------------------------
105           Helper macro: copy one XPT file to DAC_XPT with a standardized
106           member name.  Called via %nrstr() inside a DATA step CALL EXECUTE
107           so that each file is processed sequentially after the driving
108           DATA step completes.
109        
110           Parameters:
111             inpath        - full path to the source .xpt file
112             outpath       - full path for the destination .xpt file
113             standard_name - desired (standardized) SAS dataset name
114        ---------------------------------------------------------------- */
115        %macro _copy_xpt_file(inpath=, outpath=, standard_name=);
116        
117            /* Open source XPT with SAS transport engine */
118            libname _xinlib xport "&inpath";
119        
120            /* Get the actual member name stored inside the XPT file */
121            proc sql noprint;
122                select memname into :_xpt_memname trimmed
123                from dictionary.tables
124                where libname = '_XINLIB';
125            quit;
126        
127            %if %length(&_xpt_memname) = 0 %then %do;
128                %put WARNING: No dataset found in XPT file: &inpath -- skipping.;
129                libname _xinlib clear;
130                %return;
131            %end;
132        
133            %let _xpt_memname_lc = %lowcase(&_xpt_memname);
134            %let _std_lc         = %lowcase(&standard_name);
135        
136            %if %upcase(&_xpt_memname) ne %upcase(&standard_name) %then %do;
137                /* Copy internal dataset to WORK under the standard name */
138                data work.&_std_lc;
139                    set _xinlib.&_xpt_memname_lc;
140                run;
4                                           The SAS System                 12:52 Tuesday, May 19, 2026

141        
142                libname _xinlib clear;
143        
144                /* Write the WORK dataset to the new XPT file */
145                libname _xoutlib xport "&outpath";
146                proc copy in=work out=_xoutlib;
147                    select &_std_lc;
148                run;
149                libname _xoutlib clear;
150        
151                /* Clean up temporary WORK dataset */
152                proc datasets lib=work nolist;
153                    delete &_std_lc;
154                quit;
155            %end;
156            %else %do;
157                /* Name already matches standard; copy file as-is */
158                libname _xoutlib xport "&outpath";
159                proc copy in=_xinlib out=_xoutlib; run;
160                libname _xinlib  clear;
161                libname _xoutlib clear;
162            %end;
163        
164        %mend _copy_xpt_file;
