170        %macro rename_study_domains;
171        
172            %let sysparm_value = &sysparm;
173            %put NOTE: [rename_study_domains] Raw SYSPARM = &sysparm_value;
174        
175            /* ---- Parse SYSPARM: input_dir|output_dir ---- */
176            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
177            %if &pipe_pos > 0 %then %do;
178                %let indir  = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
179                %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
180            %end;
181            %else %do;
182                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
183                %abort;
184            %end;
185        
186            %put NOTE: [rename_study_domains] Input Directory  = &indir;
187            %put NOTE: [rename_study_domains] Output Directory = &outdir;
188        
189            /* ---- Derive output folder name from the input directory leaf segment ---- */
190            /* Handles both Windows backslash and Unix forward slash separators.         */
191            %let parent_folder_name = %scan(&indir, -1, \/);
192            %let dac_sas_folder     = DAC_&parent_folder_name;
193            %put NOTE: [rename_study_domains] SAS output folder name = &dac_sas_folder;
194        
5                                           The SAS System                 12:52 Tuesday, May 19, 2026

195            /* ---- Validate directories ---- */
196            %if %sysfunc(fileexist(&indir))  = 0 %then %do;
197                %put ERROR: Input directory does not exist: &indir;
198                %abort;
199            %end;
200            %if %sysfunc(fileexist(&outdir)) = 0 %then %do;
201                %put ERROR: Output directory does not exist: &outdir;
202                %abort;
203            %end;
204        
205        
206            /* ============================================================
207               PART 1: Process SAS7BDAT files
208               Uses dictionary.tables to discover library members, then
209               renames with proc datasets change (logic from
210               rename_study_domains_ZRlocalCopy.sas).
211               ============================================================ */
212        
213            /* Point a libname at the input directory so SAS can query its
214               member metadata via dictionary.tables */
215            libname _inlib "&indir";
216        
217            /* Build a table of datasets that need renaming (have a suffix).
218               Standard name = last token after the final underscore, e.g.
219               BERKELEY_AE -> AE, BERKELEY_SUPPAE -> SUPPAE. */
220            proc sql noprint;
221                create table _work_sas as
222                select
223                    memname,
224                    scan(memname, -1, '_') as standard_name length=32
225                from dictionary.tables
226                where upcase(libname) = '_INLIB'
227                  and index(memname, '_') > 0;
228        
229                select count(*) into :sas_rename_count trimmed from _work_sas;
230        
231                select count(*) into :sas_total trimmed
232                from dictionary.tables
233                where upcase(libname) = '_INLIB';
234            quit;
235        
236            %put NOTE: Found &sas_total SAS7BDAT dataset(s) in library, &sas_rename_count require
236      ! renaming.;
237        
238            %if &sas_rename_count > 0 %then %do;
239        
240                /* Check for duplicate standard names and warn/exclude */
241                proc sql noprint;
242                    create table _work_sas_dups as
243                    select standard_name, count(*) as n
244                    from _work_sas
245                    group by standard_name
246                    having count(*) > 1;
247                    select count(*) into :sas_dup_count trimmed from _work_sas_dups;
6                                           The SAS System                 12:52 Tuesday, May 19, 2026

248                quit;
249        
250                %if &sas_dup_count > 0 %then %do;
251                    %put WARNING: Multiple SAS datasets map to the same standard name.;
252                    %put WARNING: The following datasets will be SKIPPED to avoid overwriting:;
253                    data _null_;
254                        set _work_sas_dups;
255                        put "  Standard name '" standard_name +(-1)
256                            "' has " n "conflicting source datasets.";
257                    run;
258                    /* Exclude datasets with duplicate standard names */
259                    proc sql noprint;
260                        delete from _work_sas
261                        where standard_name in (select standard_name from _work_sas_dups);
262                    quit;
263                    /* Re-count after exclusion */
264                    proc sql noprint;
265                        select count(*) into :sas_rename_count trimmed from _work_sas;
266                    quit;
267                %end;
268        
269                proc datasets lib=work nolist; delete _work_sas_dups; quit;
270        
271                %if &sas_rename_count > 0 %then %do;
272        
273                    /* Create DAC_<ParentFolderName> output directory if needed */
274                    %let dac_sas_dir   = &outdir\&dac_sas_folder;
275                    %let dac_sas_exist = %sysfunc(fileexist(&dac_sas_dir));
276        
277                    %if &dac_sas_exist = 0 %then %do;
278                        %put NOTE: Creating directory &dac_sas_dir;
279                        %let _rc = %sysfunc(dcreate(&dac_sas_folder, &outdir));
280                        %if &_rc = %then %do;
281                            %put ERROR: Failed to create directory &dac_sas_dir;
282                            libname _inlib clear;
283                            %abort;
284                        %end;
285                    %end;
286                    %else %do;
287                        %put NOTE: Directory &dac_sas_dir already exists.;
288                    %end;
289        
290                    /* Copy ALL datasets from input library to &dac_sas_folder so the
291                       output folder is a complete, self-consistent set.
292                       Original input files are never modified. */
293                    libname _outdac "&dac_sas_dir";
294                    proc copy in=_inlib out=_outdac memtype=data; run;
295                    libname _inlib clear;
296        
297                    /* Rename datasets that have suffixes in &dac_sas_folder using
298                       proc datasets change (same approach as the original script) */
299                    data _null_;
300                        set _work_sas;
301                        cmd = 'proc datasets lib=_outdac nolist; change ' ||
7                                           The SAS System                 12:52 Tuesday, May 19, 2026

302                              strip(memname) || ' = ' || strip(standard_name) || '; quit;';
303                        call execute(cmd);
304                        put cmd;
305                    run;
306        
307                    libname _outdac clear;
308        
309                    %put NOTE: SAS dataset standardization complete.;
310                    %put NOTE: Standardized SAS files are in: &dac_sas_dir;
311        
312                %end; /* sas_rename_count > 0 after dedup */
313        
314            %end; /* sas_rename_count > 0 */
315            %else %do;
316                %put NOTE: All &sas_total SAS7BDAT dataset(s) already have standard names. No
316      ! &dac_sas_folder folder created.;
317                libname _inlib clear;
318            %end;
319        
320            proc datasets lib=work nolist; delete _work_sas; quit;
321        
322        
323            /* ============================================================
324               PART 2: Process XPT files
325               ============================================================ */
326        
327            filename _xptlst pipe "dir /b ""&indir\*.xpt"" 2>nul";
328        
329            data _work_xpt;
330                infile _xptlst truncover;
331                input filename $256.;
332                if filename = '' then delete;
333                length dsname $32 standard_name $32
