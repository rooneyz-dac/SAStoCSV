338                xpt_in_path   = "&indir\" || strip(filename);
339                xpt_out_path  = "&outdir\DAC_XPT\" ||
340                                strip(lowcase(standard_name)) || '.xpt';
341            run;
342        
343            filename _xptlst clear;
344        
345            proc sql noprint;
346                select count(*) into :xpt_total        trimmed from _work_xpt;
347                select count(*) into :xpt_rename_count trimmed from _work_xpt
