1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : rename_study_domains_cli20260320.sas
3          | SHORT DESC   : Standardizes SAS and XPT dataset names by removing
4          |                suffixes (e.g., AE_PLACEBO to AE) and placing
5          |                renamed copies in DAC_<ParentFolderName> or DAC_XPT subfolders
6          *------------------------------------------------------------------*
7          | CREATED BY   : DAC Development Team
8          | DATE CREATED : 2026-05-08
9          | VERSION      : 1.4
10         *------------------------------------------------------------------*
11         | PURPOSE
12         | Checks SAS (.sas7bdat) and XPT (.xpt) datasets in the specified
13         | input directory and standardizes their names by removing
14         | study-specific suffixes (e.g., converting AE_PLACEBO to AE).
15         | When any dataset requires renaming, ALL datasets of that type are
16         | copied with standardized names to a new subfolder:
17         |   - DAC_<ParentFolderName> for .sas7bdat files
18         |   - DAC_XPT for .xpt files
2                                           The SAS System                  14:45 Monday, July 6, 2026

19         | This ensures that subsequent pipeline scripts operate on a
20         | complete, consistently named set of datasets.
21         |
22         | Naming rule: the standard name is the portion of the dataset name
23         | after the last underscore (scan(memname, -1, '_')).  E.g.:
24         |   BERKELEY_AE   -> AE
25         |   BERKELEY_SUPPAE -> SUPPAE
26         |   CM          -> CM  (unchanged; no folder created for this alone)
27         |
28         | 1.1: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
29         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
30         |                    files to be renamed
31         | OUTPUT_DIRECTORY = Path to folder where DAC_<ParentFolderName>
32         |                    and/or DAC_XPT subfolders will be created.
33         |                    Must exist prior to execution.
34         |
35         | USAGE:
36         |   sas -sysparm "input_directory|output_directory"
37         |       -sysin rename_study_domains_cli20260320.sas
38         |
39         | OUTPUT STRUCTURE:
40         |   output_directory\
41         |   ├── DAC_<ParentFolderName>\  - Standardized SAS7BDAT datasets
42         |   │                              (created only when any .sas7bdat
43         |   │                               dataset has a non-standard suffix)
44         |   └── DAC_XPT\   - Standardized XPT datasets
45         |                     (created only when any .xpt file has
46         |                      a non-standard suffix)
47         *------------------------------------------------------------------*
48         | OPERATING SYSTEM COMPATIBILITY
49         | SAS v9.4 or Higher: Yes
50         | Windows:            Yes
51         *------------------------------------------------------------------*
52         | NOTES
53         | - If two input datasets share the same standard name (e.g.,
54         |   AE_PLACEBO and AE_TREATMENT both map to AE), a WARNING is
55         |   issued and those datasets are skipped.  Resolve naming conflicts
56         |   in the source data before running the pipeline.
57         | - For XPT files the script queries the SAS transport library to
58         |   obtain the actual member name inside each file.  SAS XPT
59         |   format limits member names to 8 characters.
60         *------------------------------------------------------------------*
61         | EXAMPLES
62         |
63         | Standardize SAS dataset names:
64         |   sas -sysparm "C:\data\input|C:\data\output"
65         |       -sysin rename_study_domains_cli20260320.sas
66         |
67         | Standardize XPT dataset names:
68         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
69         |       -sysin rename_study_domains_cli20260320.sas
70         *------------------------------------------------------------------*/
71         
72         /* ----------------------------------------------------------------
3                                           The SAS System                  14:45 Monday, July 6, 2026

73            Helper macro: copy one XPT file to DAC_XPT with a standardized
74            member name.  Called via %nrstr() inside a DATA step CALL EXECUTE
75            so that each file is processed sequentially after the driving
76            DATA step completes.
77         
78            Parameters:
79              inpath        - full path to the source .xpt file
80              outpath       - full path for the destination .xpt file
81              standard_name - desired (standardized) SAS dataset name
82         ---------------------------------------------------------------- */
83         %macro _copy_xpt_file(inpath=, outpath=, standard_name=);
84         
85             /* Open source XPT with SAS transport engine */
86             libname _xinlib xport "&inpath";
87         
88             /* Get the actual member name stored inside the XPT file */
89             proc sql noprint;
90                 select memname into :_xpt_memname trimmed
91                 from dictionary.tables
92                 where libname = '_XINLIB';
93             quit;
94         
95             %if %length(&_xpt_memname) = 0 %then %do;
96                 %put WARNING: No dataset found in XPT file: &inpath -- skipping.;
97                 libname _xinlib clear;
98                 %return;
99             %end;
100        
101            %let _xpt_memname_lc = %lowcase(&_xpt_memname);
102            %let _std_lc         = %lowcase(&standard_name);
103        
104            %if %upcase(&_xpt_memname) ne %upcase(&standard_name) %then %do;
105                /* Copy internal dataset to WORK under the standard name */
106                data work.&_std_lc;
107                    set _xinlib.&_xpt_memname_lc;
108                run;
109        
110                libname _xinlib clear;
111        
112                /* Write the WORK dataset to the new XPT file */
113                libname _xoutlib xport "&outpath";
114                proc copy in=work out=_xoutlib;
115                    select &_std_lc;
116                run;
117                libname _xoutlib clear;
118        
119                /* Clean up temporary WORK dataset */
120                proc datasets lib=work nolist;
121                    delete &_std_lc;
122                quit;
123            %end;
124            %else %do;
125                /* Name already matches standard; copy file as-is */
126                libname _xoutlib xport "&outpath";
4                                           The SAS System                  14:45 Monday, July 6, 2026

127                proc copy in=_xinlib out=_xoutlib; run;
128                libname _xinlib  clear;
129                libname _xoutlib clear;
130            %end;
131        
132        %mend _copy_xpt_file;
133        
