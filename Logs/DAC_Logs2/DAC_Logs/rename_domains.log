136           Main macro
137        ================================================================ */
138        %macro rename_study_domains;
139        
140            %let sysparm_value = &sysparm;
141            %put NOTE: [rename_study_domains] Raw SYSPARM = &sysparm_value;
142        
143            /* ---- Parse SYSPARM: input_dir|output_dir ---- */
144            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
145            %if &pipe_pos > 0 %then %do;
146                %let indir  = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
147                %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
148            %end;
149            %else %do;
150                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
151                %abort;
152            %end;
153        
154            %put NOTE: [rename_study_domains] Input Directory  = &indir;
155            %put NOTE: [rename_study_domains] Output Directory = &outdir;
156        
157            /* ---- Derive output folder name from the input directory leaf segment ---- */
158            /* Handles both Windows backslash and Unix forward slash separators.         */
159            %let parent_folder_name = %scan(&indir, -1, \/);
160            %let dac_sas_folder     = DAC_&parent_folder_name;
161            %put NOTE: [rename_study_domains] SAS output folder name = &dac_sas_folder;
162        
163            /* ---- Validate directories ---- */
164            %if %sysfunc(fileexist(&indir))  = 0 %then %do;
165                %put ERROR: Input directory does not exist: &indir;
166                %abort;
167            %end;
168            %if %sysfunc(fileexist(&outdir)) = 0 %then %do;
169                %put ERROR: Output directory does not exist: &outdir;
170                %abort;
171            %end;
172        
173        
174            /* ============================================================
175               PART 1: Process SAS7BDAT files
176               Uses dictionary.tables to discover library members, then
177               renames with proc datasets change (logic from
178               rename_study_domains_ZRlocalCopy.sas).
179               ============================================================ */
180        
5                                           The SAS System                  14:45 Monday, July 6, 2026

181            /* Point a libname at the input directory so SAS can query its
182               member metadata via dictionary.tables */
183            libname _inlib "&indir";
184        
185            /* Build a table of datasets that need renaming (have a suffix).
186               Standard name = last token after the final underscore, e.g.
187               BERKELEY_AE -> AE, BERKELEY_SUPPAE -> SUPPAE. */
188            proc sql noprint;
189                create table _work_sas as
190                select
191                    memname,
192                    scan(memname, -1, '_') as standard_name length=32
193                from dictionary.tables
194                where upcase(libname) = '_INLIB'
195                  and index(memname, '_') > 0;
196        
197                select count(*) into :sas_rename_count trimmed from _work_sas;
198        
199                select count(*) into :sas_total trimmed
200                from dictionary.tables
201                where upcase(libname) = '_INLIB';
202            quit;
203        
204            %put NOTE: Found &sas_total SAS7BDAT dataset(s) in library, &sas_rename_count require
204      ! renaming.;
205        
206            %if &sas_rename_count > 0 %then %do;
207        
208                /* Check for duplicate standard names and warn/exclude */
209                proc sql noprint;
210                    create table _work_sas_dups as
211                    select standard_name, count(*) as n
212                    from _work_sas
213                    group by standard_name
214                    having count(*) > 1;
215                    select count(*) into :sas_dup_count trimmed from _work_sas_dups;
216                quit;
217        
218                %if &sas_dup_count > 0 %then %do;
219                    %put WARNING: Multiple SAS datasets map to the same standard name.;
220                    %put WARNING: The following datasets will be SKIPPED to avoid overwriting:;
221                    data _null_;
222                        set _work_sas_dups;
223                        put "  Standard name '" standard_name +(-1)
224                            "' has " n "conflicting source datasets.";
225                    run;
226                    /* Exclude datasets with duplicate standard names */
227                    proc sql noprint;
228                        delete from _work_sas
229                        where standard_name in (select standard_name from _work_sas_dups);
230                    quit;
231                    /* Re-count after exclusion */
232                    proc sql noprint;
233                        select count(*) into :sas_rename_count trimmed from _work_sas;
6                                           The SAS System                  14:45 Monday, July 6, 2026

234                    quit;
235                %end;
236        
237                proc datasets lib=work nolist; delete _work_sas_dups; quit;
238        
239                %if &sas_rename_count > 0 %then %do;
240        
241                    /* Create DAC_<ParentFolderName> output directory if needed */
242                    %let dac_sas_dir   = &outdir\&dac_sas_folder;
243                    %let dac_sas_exist = %sysfunc(fileexist(&dac_sas_dir));
244        
245                    %if &dac_sas_exist = 0 %then %do;
246                        %put NOTE: Creating directory &dac_sas_dir;
247                        %let _rc = %sysfunc(dcreate(&dac_sas_folder, &outdir));
248                        %if %length(&_rc) = 0 %then %do;
249                            %put ERROR: Failed to create directory &dac_sas_dir;
250                            libname _inlib clear;
251                            %abort;
252                        %end;
253                    %end;
254                    %else %do;
255                        %put NOTE: Directory &dac_sas_dir already exists.;
256                    %end;
257        
258                    /* Copy ALL datasets from input library to &dac_sas_folder so the
259                       output folder is a complete, self-consistent set.
260                       Original input files are never modified. */
261                    libname _outdac "&dac_sas_dir";
262                    proc copy in=_inlib out=_outdac memtype=data; run;
263                    libname _inlib clear;
264        
265                    /* Rename datasets that have suffixes in &dac_sas_folder using
266                       proc datasets change (same approach as the original script) */
267                    data _null_;
268                        set _work_sas;
269                        cmd = 'proc datasets lib=_outdac nolist; change ' ||
270                              strip(memname) || ' = ' || strip(standard_name) || '; quit;';
271                        call execute(cmd);
272                        put cmd;
273                    run;
274        
275                    libname _outdac clear;
276        
277                    %put NOTE: SAS dataset standardization complete.;
278                    %put NOTE: Standardized SAS files are in: &dac_sas_dir;
279        
280                %end; /* sas_rename_count > 0 after dedup */
281        
282            %end; /* sas_rename_count > 0 */
283            %else %do;
284                %put NOTE: All &sas_total SAS7BDAT dataset(s) already have standard names. No
284      ! &dac_sas_folder folder created.;
285                libname _inlib clear;
286            %end;
7                                           The SAS System                  14:45 Monday, July 6, 2026

287        
288            proc datasets lib=work nolist; delete _work_sas; quit;
289        
290        
291            /* ============================================================
292               PART 2: Process XPT files
293               ============================================================ */
294        
295            filename _xptlst pipe "dir /b ""&indir\*.xpt"" 2>nul";
296        
297            data _work_xpt;
298                infile _xptlst truncover;
299                input filename $256.;
300                if filename = '' then delete;
301                length dsname $32 standard_name $32
302                       xpt_in_path $512 xpt_out_path $512;
303                dsname        = upcase(scan(filename, 1, '.'));
304                standard_name = upcase(scan(dsname,  -1, '_'));
305                needs_rename  = (dsname ne standard_name);
306                xpt_in_path   = "&indir\" || strip(filename);
307                xpt_out_path  = "&outdir\DAC_XPT\" ||
308                                strip(lowcase(standard_name)) || '.xpt';
309            run;
310        
311            filename _xptlst clear;
312        
313            proc sql noprint;
314                select count(*) into :xpt_total        trimmed from _work_xpt;
315                select count(*) into :xpt_rename_count trimmed from _work_xpt
316                    where needs_rename = 1;
317            quit;
318        
319            %put NOTE: Found &xpt_total XPT file(s), &xpt_rename_count require renaming.;
320        
321            %if &xpt_total > 0 and &xpt_rename_count > 0 %then %do;
322        
323                /* Check for duplicate standard names and warn/exclude */
324                proc sql noprint;
325                    create table _work_xpt_dups as
326                    select standard_name, count(*) as n
327                    from _work_xpt
328                    group by standard_name
329                    having count(*) > 1;
330                    select count(*) into :xpt_dup_count trimmed from _work_xpt_dups;
331                quit;
332        
333                %if &xpt_dup_count > 0 %then %do;
334                    %put WARNING: Multiple XPT datasets map to the same standard name.;
335                    %put WARNING: The following XPT datasets will be SKIPPED:;
336                    data _null_;
337                        set _work_xpt_dups;
338                        put "  Standard name '" standard_name +(-1)
339                            "' has " n "conflicting source datasets.";
340                    run;
8                                           The SAS System                  14:45 Monday, July 6, 2026

341                    proc sql noprint;
342                        delete from _work_xpt
343                        where standard_name in (select standard_name from _work_xpt_dups);
344                    quit;
345                    proc sql noprint;
346                        select count(*) into :xpt_total        trimmed from _work_xpt;
347                        select count(*) into :xpt_rename_count trimmed from _work_xpt
348                            where needs_rename = 1;
349                    quit;
350                %end;
351        
352                proc datasets lib=work nolist; delete _work_xpt_dups; quit;
353        
354                %if &xpt_rename_count > 0 %then %do;
355        
356                    /* Create DAC_XPT output directory if needed */
357                    %let dac_xpt_dir   = &outdir\DAC_XPT;
358                    %let dac_xpt_exist = %sysfunc(fileexist(&dac_xpt_dir));
359        
360                    %if &dac_xpt_exist = 0 %then %do;
361                        %put NOTE: Creating directory &dac_xpt_dir;
362                        %let _rc = %sysfunc(dcreate(DAC_XPT, &outdir));
363                        %if %length(&_rc) = 0 %then %do;
364                            %put ERROR: Failed to create directory &dac_xpt_dir;
365                            %abort;
366                        %end;
367                    %end;
368                    %else %do;
369                        %put NOTE: Directory &dac_xpt_dir already exists.;
370                    %end;
371        
372                    /* Generate a call to %_copy_xpt_file for each XPT file.
373                       Using %nrstr prevents premature macro resolution of the
374                       parameter values inside the DATA step. */
375                    data _null_;
376                        set _work_xpt;
377                        call execute(
378                            '%_copy_xpt_file(inpath=' || strip(xpt_in_path)   ||
379                            ', outpath='              || strip(xpt_out_path)  ||
380                            ', standard_name='        || strip(standard_name) || ')'
381                        );
382                    run;
383        
384                    %put NOTE: XPT dataset standardization complete.;
385                    %put NOTE: Standardized XPT files are in: &dac_xpt_dir;
386        
387                %end; /* xpt_rename_count > 0 after dedup */
388        
389            %end; /* xpt_total > 0 and xpt_rename_count > 0 */
390            %else %if &xpt_total > 0 %then %do;
391                %put NOTE: All &xpt_total XPT file(s) already have standard names. No DAC_XPT
391      ! folder created.;
392            %end;
393        
