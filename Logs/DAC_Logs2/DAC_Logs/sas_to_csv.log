154        /* 6) Macro to export all datasets to CSV in csv_dir */
155        %macro export_all_to_csv;
156            %local n i dsname nvar _err_count;
157            %let _err_count = 0;
158        
159            proc sql noprint;
160                select count(*) into :n trimmed from work._dslist;
161            quit;
162        
163            %if &n = 0 %then %do;
164                %put NOTE: No SAS datasets found in &in_dir;
165                %return;
166            %end;
167        
168            %do i = 1 %to &n;
169                proc sql noprint;
170                    select memname into :dsname trimmed
171                    from work._dslist
172                    where monotonic() = &i;
173                quit;
174        
175                /* Check that the dataset has at least one variable before exporting */
176                proc sql noprint;
177                    select count(*) into :nvar trimmed
178                    from dictionary.columns
179                    where libname = upcase('INLIB')
180                      and memname = upcase("&dsname");
181                quit;
182        
183                %if &nvar = 0 %then %do;
184                    %put WARNING: Skipping INLIB.&dsname - dataset has no variables defined.;
185                    %let _err_count = %eval(&_err_count + 1);
186                %end;
187                %else %do;
188                    %let csvfile = &csv_dir.\&dsname..csv;
189                    %put NOTE: Exporting INLIB.&dsname to &csvfile;
190                    proc export data=inlib.&dsname
191                        outfile="&csvfile"
192                        dbms=csv
6                                           The SAS System                  14:45 Monday, July 6, 2026

193                        replace;
194                    run;
195                %end;
196            %end;
197        
198            /* Pass error count out of macro scope */
199            %global _export_err_count;
200            %let _export_err_count = &_err_count;
201        %mend export_all_to_csv;
202        
203        %export_all_to_csv;
