1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoXPTcli20260320.sas
3          | SHORT DESC   : Bidirectional batch conversion between SAS7BDAT
4          |                and XPT (SAS Transport) formats via CLI
5          *------------------------------------------------------------------*
6          | CREATED BY   : DAC Development Team
7          | DATE CREATED : 2025-11-21
8          | VERSION      : 2.1
9          *------------------------------------------------------------------*
10         | PURPOSE
11         | Performs batch bidirectional conversion of SAS datasets between
12         | SAS7BDAT and XPT (SAS Transport) formats. When .sas7bdat files
13         | are detected in the input directory they are converted to .xpt
14         | and placed in OUTDIR\DAC_XPT. When .xpt files are detected they
15         | are converted to .sas7bdat and placed in OUTDIR\DAC_SDTM. Both
16         | conversion types may occur in a single run. An error log
17         | (xpt_error_log.txt) is written to the DAC_Logs subdirectory.
18         |
2                                           The SAS System                  14:45 Monday, July 6, 2026

19         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
20         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
21         |                    files to be converted
22         | OUTPUT_DIRECTORY = Path to folder where output subfolders and
23         |                    the error log will be created. Must exist
24         |                    prior to execution.
25         |
26         | 2.0: XPT FORMAT LIMITATIONS
27         | MEMBER NAMES     = Limited to 8 characters by the XPT format
28         |                    specification. Dataset names longer than 8
29         |                    characters are automatically truncated to the
30         |                    first 4 characters concatenated with the last
31         |                    4 characters.
32         |                    Example: "berkeley_pbo_ae" becomes "berkl_ae"
33         |
34         | USAGE:
35         |   sas -sysparm "input_directory|output_directory"
36         |       -sysin SAStoXPTcli20260320.sas
37         |
38         | OUTPUT STRUCTURE:
39         |   output_directory\
40         |   ├── DAC_XPT\          - XPT exports (from .sas7bdat input)
41         |   ├── DAC_SDTM\         - SAS7BDAT exports (from .xpt input)
42         |   └── DAC_Logs\
43         |       └── xpt_error_log.txt - Conversion activity and error log
44         *------------------------------------------------------------------*
45         | OPERATING SYSTEM COMPATIBILITY
46         | SAS v9.4 or Higher: Yes
47         | Windows:            Yes (uses DIR command for file listing)
48         *------------------------------------------------------------------*
49         | MACRO CALL
50         |
51         | Not applicable. Script is invoked directly via the SAS command
52         | line using -sysin and -sysparm.
53         *------------------------------------------------------------------*
54         | EXAMPLES
55         |
56         | Convert SAS datasets to XPT format:
57         |   sas -sysparm "C:\data\input|C:\data\output"
58         |       -sysin SAStoXPTcli20260320.sas
59         |
60         | Convert XPT files back to SAS7BDAT:
61         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
62         |       -sysin SAStoXPTcli20260320.sas
63         |
64         | Process a mixed directory (both .sas7bdat and .xpt present):
65         |   sas -sysparm "C:\data\mixed|C:\data\output"
66         |       -sysin SAStoXPTcli20260320.sas
67         *------------------------------------------------------------------*/
68         
69         %macro convert_files;
70             %let sysparm_value = &sysparm;
71             %put DEBUG: Raw SYSPARM value = &sysparm_value;
72         
3                                           The SAS System                  14:45 Monday, July 6, 2026

73             %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
74             %put DEBUG: Pipe position = &pipe_pos;
75         
76             %if &pipe_pos > 0 %then %do;
77                 %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
78                 %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
79             %end;
80             %else %do;
81                 %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
82                 %abort;
83             %end;
84         
85             %put DEBUG: Input Directory = &indir;
86             %put DEBUG: Output Directory = &outdir;
87         
88             %let indir_exist = %sysfunc(fileexist(&indir));
89             %let outdir_exist = %sysfunc(fileexist(&outdir));
90         
91             %if &indir_exist = 0 %then %do;
92                 %put ERROR: Input directory does not exist: &indir;
93                 %abort;
94             %end;
95         
96             %if &outdir_exist = 0 %then %do;
97                 %put ERROR: Output directory does not exist: &outdir;
98                 %abort;
99             %end;
100        
101            /* Create DAC_Logs subfolder if it does not exist */
102            %let dac_logs_dir = &outdir\DAC_Logs;
103            %let dac_logs_exist = %sysfunc(fileexist(&dac_logs_dir));
104            %if &dac_logs_exist = 0 %then %do;
105                %let rc = %sysfunc(dcreate(DAC_Logs, &outdir));
106                %if %length(&rc) = 0 %then %do;
107                    %put ERROR: Failed to create directory &dac_logs_dir;
108                    %abort;
109                %end;
110            %end;
111        
112            %let errlog = &outdir\DAC_Logs\xpt_error_log.txt;
113        
114            data _null_;
115                file "&errlog";
116                length dt $19;
117                dt = put(datetime(), datetime19.);
118                put "Error Log - " dt;
119                put "Input Directory: &indir";
120                put "Output Directory: &outdir";
121                put "----------------------------------------";
122            run;
123        
124            filename infiles pipe "dir /b ""&indir\*.sas7bdat"" ""&indir\*.xpt"" 2>nul";
125        
126            data file_list;
4                                           The SAS System                  14:45 Monday, July 6, 2026

127                infile infiles truncover;
128                input filename $256.;
129                length filetype $10;
130                if index(upcase(filename), '.SAS7BDAT') > 0 then filetype = 'SAS7BDAT';
131                else if index(upcase(filename), '.XPT') > 0 then filetype = 'XPT';
132            run;
133        
134            filename infiles clear;
135        
136            proc sql noprint;
137                select count(*) into :sas7bdat_count trimmed from file_list where filetype =
137      ! 'SAS7BDAT';
138                select count(*) into :xpt_count trimmed from file_list where filetype = 'XPT';
139            quit;
140        
141            %put DEBUG: Found &sas7bdat_count SAS7BDAT files;
142            %put DEBUG: Found &xpt_count XPT files;
143        
144            %if &sas7bdat_count > 0 %then %do;
145                %let xpt_dir = &outdir\DAC_XPT;
146                %let xpt_exist = %sysfunc(fileexist(&xpt_dir));
147        
148                %if &xpt_exist = 0 %then %do;
149                    %put DEBUG: Creating directory &xpt_dir;
150                    %let rc = %sysfunc(dcreate(DAC_XPT, &outdir));
151                    %if %length(&rc) = 0 %then %do;
152                        %put ERROR: Failed to create directory &xpt_dir;
153                        %abort;
154                    %end;
155                %end;
156        
157                libname inlib "&indir";
158        
159                data _null_;
160                    set file_list end=eof;
161                    where filetype = 'SAS7BDAT';
162        
163                    length dsname memname $32 xpt_path $256;
164        
165                    dsname = scan(filename, 1, '.');
166        
167                    /* Truncate to first 4 + last 4 characters for XPT compliance */
168                    if length(dsname) > 8 then
169                        memname = substr(dsname, 1, 4) || substr(dsname, length(dsname) - 3, 4);
170                    else
171                        memname = dsname;
172        
173                    xpt_path = "&xpt_dir\" || strip(memname) || ".xpt";
174        
175                    call execute('libname xptlib xport "' || strip(xpt_path) || '";');
176        
177                    /* Use PROC DATASETS to rename, then PROC COPY to transfer */
178                    if dsname ne memname then do;
179                        call execute('proc datasets library=inlib nolist; change ' || strip(dsname)
5                                           The SAS System                  14:45 Monday, July 6, 2026

179      !  || '=' || strip(memname) || '; quit;');
180                    end;
181        
182                    call execute('proc copy in=inlib out=xptlib memtype=data; select ' ||
182      ! strip(memname) || '; run;');
183        
184                    /* Rename back if needed */
185                    if dsname ne memname then do;
186                        call execute('proc datasets library=inlib nolist; change ' ||
186      ! strip(memname) || '=' || strip(dsname) || '; quit;');
187                    end;
188        
189                    call execute('libname xptlib clear;');
190        
191                    file "&errlog" mod;
192                    put "Converted to XPT: " dsname " -> " memname " (" xpt_path ")";
193        
194                    if eof then do;
195                        put "----------------------------------------";
196                        put "Total SAS7BDAT files processed: " _n_;
197                    end;
198                run;
199        
200                libname inlib clear;
201            %end;
202        
203            %if &xpt_count > 0 %then %do;
204                %let sdtm_dir = &outdir\DAC_SDTM;
205                %let sdtm_exist = %sysfunc(fileexist(&sdtm_dir));
206        
207                %if &sdtm_exist = 0 %then %do;
208                    %put DEBUG: Creating directory &sdtm_dir;
209                    %let rc = %sysfunc(dcreate(DAC_SDTM, &outdir));
210                    %if %length(&rc) = 0 %then %do;
211                        %put ERROR: Failed to create directory &sdtm_dir;
212                        %abort;
213                    %end;
214                %end;
215        
216                libname outsdtm "&sdtm_dir";
217        
218                data _null_;
219                    set file_list end=eof;
220                    where filetype = 'XPT';
221        
222                    length dsname $32;
223        
224                    dsname = scan(filename, 1, '.');
225        
226                    call execute('libname xptlib xport "' || "&indir\" || strip(filename) || '";');
227                    call execute('proc copy in=xptlib out=outsdtm; run;');
228                    call execute('libname xptlib clear;');
229        
230                    file "&errlog" mod;
6                                           The SAS System                  14:45 Monday, July 6, 2026

231                    put "Converted to SAS7BDAT: " dsname;
232        
233                    if eof then do;
234                        put "----------------------------------------";
235                        put "Total XPT files processed: " _n_;
236                    end;
237                run;
238        
239                libname outsdtm clear;
240            %end;
241        
242            %put DEBUG: Conversion process completed;
243        
244            data _null_;
245                file "&errlog" mod;
246                length dt $19;
247                dt = put(datetime(), datetime19.);
248                put "----------------------------------------";
249                put "Process completed: " dt;
250            run;
251        
252        %mend convert_files;
253        
254        %convert_files;
