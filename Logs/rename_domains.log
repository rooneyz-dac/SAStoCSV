1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : rename_study_domains_cli20260320.sas
3          | SHORT DESC   : Standardizes SAS and XPT dataset names by removing
4          |                suffixes (e.g., AE_PLACEBO to AE) and placing
5          |                renamed copies in DAC_SAS or DAC_XPT subfolders
6          *------------------------------------------------------------------*
7          | CREATED BY   : DAC Development Team
8          | DATE CREATED : 2026-05-08
9          | VERSION      : 1.0
10         *------------------------------------------------------------------*
11         | VERSION UPDATES:
12         | 2026-05-08: Initial CLI release (v1.0)
13         |   - Added SYSPARM parsing for input and output directories
14         |   - Standardizes dataset names by keeping only the prefix before
15         |     the first underscore (e.g., AE_PLACEBO -> AE)
16         |   - Copies SAS7BDAT datasets to DAC_SAS subfolder when any file
17         |     in the input directory has a non-standard (suffixed) name
18         |   - Copies XPT datasets to DAC_XPT subfolder when any XPT file
19         |     in the input directory has a non-standard name
20         |   - Files without underscores are copied unchanged to the new
21         |     folder so the folder is a complete, self-consistent set
22         *------------------------------------------------------------------*
23         | PURPOSE
24         | Checks SAS (.sas7bdat) and XPT (.xpt) datasets in the specified
25         | input directory and standardizes their names by removing
2                                           The SAS System                 14:44 Tuesday, May 12, 2026

26         | study-specific suffixes (e.g., converting AE_PLACEBO to AE).
27         | When any file requires renaming, ALL files of that type are
28         | copied with standardized names to a new subfolder:
29         |   - DAC_SAS for .sas7bdat files
30         |   - DAC_XPT for .xpt files
31         | This ensures that subsequent pipeline scripts operate on a
32         | complete, consistently named set of datasets.
33         |
34         | Naming rule: the standard name is the portion of the dataset name
35         | before the first underscore.  E.g.:
36         |   AE_PLACEBO  -> AE
37         |   DM_TRT      -> DM
38         |   CM          -> CM  (unchanged; no folder created for this alone)
39         |
40         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
41         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
42         |                    files to be renamed
43         | OUTPUT_DIRECTORY = Path to folder where DAC_SAS and/or DAC_XPT
44         |                    subfolders will be created. Must exist prior
45         |                    to execution.
46         |
47         | USAGE:
48         |   sas -sysparm "input_directory|output_directory"
49         |       -sysin rename_study_domains_cli20260320.sas
50         |
51         | OUTPUT STRUCTURE:
52         |   output_directory\
53         |   +-- DAC_SAS\    - Standardized SAS7BDAT datasets
54         |   ¦                 (created only when any .sas7bdat file has
55         |   ¦                  a non-standard suffix)
56         |   +-- DAC_XPT\   - Standardized XPT datasets
57         |                     (created only when any .xpt file has
58         |                      a non-standard suffix)
59         *------------------------------------------------------------------*
60         | OPERATING SYSTEM COMPATIBILITY
61         | SAS v9.4 or Higher: Yes
62         | Windows:            Yes (uses DIR command for file listing)
63         *------------------------------------------------------------------*
64         | NOTES
65         | - If two input files share the same standard name (e.g.,
66         |   AE_PLACEBO and AE_TREATMENT both map to AE), a WARNING is
67         |   issued and those files are skipped.  Resolve naming conflicts
68         |   in the source data before running the pipeline.
69         | - For XPT files the script queries the SAS transport library to
70         |   obtain the actual member name inside each file.  SAS XPT
71         |   format limits member names to 8 characters.
72         *------------------------------------------------------------------*
73         | EXAMPLES
74         |
75         | Standardize SAS dataset names:
76         |   sas -sysparm "C:\data\input|C:\data\output"
77         |       -sysin rename_study_domains_cli20260320.sas
78         |
79         | Standardize XPT dataset names:
3                                           The SAS System                 14:44 Tuesday, May 12, 2026

80         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
81         |       -sysin rename_study_domains_cli20260320.sas
82         *------------------------------------------------------------------*/
83         
84         /* ----------------------------------------------------------------
85            Helper macro: copy one XPT file to DAC_XPT with a standardized
86            member name.  Called via %nrstr() inside a DATA step CALL EXECUTE
87            so that each file is processed sequentially after the driving
88            DATA step completes.
89         
90            Parameters:
91              inpath        - full path to the source .xpt file
92              outpath       - full path for the destination .xpt file
93              standard_name - desired (standardized) SAS dataset name
94         ---------------------------------------------------------------- */
95         %macro _copy_xpt_file(inpath=, outpath=, standard_name=);
96         
97             /* Open source XPT with SAS transport engine */
98             libname _xinlib xport "&inpath";
99         
100            /* Get the actual member name stored inside the XPT file */
101            proc sql noprint;
102                select memname into :_xpt_memname trimmed
103                from dictionary.tables
104                where libname = '_XINLIB';
105            quit;
106        
107            %if %length(&_xpt_memname) = 0 %then %do;
108                %put WARNING: No dataset found in XPT file: &inpath -- skipping.;
109                libname _xinlib clear;
110                %return;
111            %end;
112        
113            %let _xpt_memname_lc = %lowcase(&_xpt_memname);
114            %let _std_lc         = %lowcase(&standard_name);
115        
116            %if %upcase(&_xpt_memname) ne %upcase(&standard_name) %then %do;
117                /* Copy internal dataset to WORK under the standard name */
118                data work.&_std_lc;
119                    set _xinlib.&_xpt_memname_lc;
120                run;
121        
122                libname _xinlib clear;
123        
124                /* Write the WORK dataset to the new XPT file */
125                libname _xoutlib xport "&outpath";
126                proc copy in=work out=_xoutlib;
127                    select &_std_lc;
128                run;
129                libname _xoutlib clear;
130        
131                /* Clean up temporary WORK dataset */
132                proc datasets lib=work nolist;
133                    delete &_std_lc;
4                                           The SAS System                 14:44 Tuesday, May 12, 2026

134                quit;
135            %end;
136            %else %do;
137                /* Name already matches standard; copy file as-is */
138                libname _xoutlib xport "&outpath";
139                proc copy in=_xinlib out=_xoutlib; run;
140                libname _xinlib  clear;
141                libname _xoutlib clear;
142            %end;
143        
144        %mend _copy_xpt_file;
