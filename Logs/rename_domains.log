150        %macro rename_study_domains;
151        
152            %let sysparm_value = &sysparm;
153            %put NOTE: [rename_study_domains] Raw SYSPARM = &sysparm_value;
154        
155            /* ---- Parse SYSPARM: input_dir|output_dir ---- */
156            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
157            %if &pipe_pos > 0 %then %do;
158                %let indir  = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
159                %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
160            %end;
161            %else %do;
162                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
163                %abort;
164            %end;
165        
166            %put NOTE: [rename_study_domains] Input Directory  = &indir;
167            %put NOTE: [rename_study_domains] Output Directory = &outdir;
168        
169            /* ---- Validate directories ---- */
170            %if %sysfunc(fileexist(&indir))  = 0 %then %do;
171                %put ERROR: Input directory does not exist: &indir;
172                %abort;
173            %end;
174            %if %sysfunc(fileexist(&outdir)) = 0 %then %do;
175                %put ERROR: Output directory does not exist: &outdir;
176                %abort;
177            %end;
178        
179        
180            /* ============================================================
181               PART 1: Process SAS7BDAT files
182               ============================================================ */
183        
184            filename _sas7b pipe "dir /b ""&indir\*.sas7bdat"" 2>nul";
185        
186            data _work_sas;
187                infile _sas7b truncover;
5                                           The SAS System                 14:44 Tuesday, May 12, 2026

188                input filename $256.;
189                if filename = '' then delete;
190                length dsname $32 standard_name $32;
191                dsname        = upcase(scan(filename, 1, '.'));
192                standard_name = upcase(scan(dsname,   1, '_'));
193                needs_rename  = (dsname ne standard_name);
194            run;
195        
196            filename _sas7b clear;
197        
198            proc sql noprint;
199                select count(*) into :sas_total        trimmed from _work_sas;
200                select count(*) into :sas_rename_count trimmed from _work_sas
201                    where needs_rename = 1;
202            quit;
203        
204            %put NOTE: Found &sas_total SAS7BDAT file(s), &sas_rename_count require renaming.;
205        
206            %if &sas_total > 0 and &sas_rename_count > 0 %then %do;
207        
208                /* Check for duplicate standard names and warn/exclude */
209                proc sql noprint;
210                    create table _work_sas_dups as
211                    select standard_name, count(*) as n
212                    from _work_sas
213                    group by standard_name
214                    having count(*) > 1;
215                    select count(*) into :sas_dup_count trimmed from _work_sas_dups;
216                quit;
217        
218                %if &sas_dup_count > 0 %then %do;
219                    %put WARNING: Multiple SAS datasets map to the same standard name.;
220                    %put WARNING: The following datasets will be SKIPPED to avoid overwriting:;
221                    data _null_;
222                        set _work_sas_dups;
223                        put "  Standard name '" standard_name +(-1)
224                            "' has " n "conflicting source datasets.";
225                    run;
226                    /* Exclude files with duplicate standard names */
227                    proc sql noprint;
228                        delete from _work_sas
229                        where standard_name in (select standard_name from _work_sas_dups);
230                    quit;
231                    /* Re-count after exclusion */
232                    proc sql noprint;
233                        select count(*) into :sas_total        trimmed from _work_sas;
234                        select count(*) into :sas_rename_count trimmed from _work_sas
235                            where needs_rename = 1;
236                    quit;
237                %end;
238        
239                proc datasets lib=work nolist; delete _work_sas_dups; quit;
240        
241                %if &sas_rename_count > 0 %then %do;
6                                           The SAS System                 14:44 Tuesday, May 12, 2026

242        
243                    /* Create DAC_SAS output directory if needed */
244                    %let dac_sas_dir   = &outdir\DAC_SAS;
245                    %let dac_sas_exist = %sysfunc(fileexist(&dac_sas_dir));
246        
247                    %if &dac_sas_exist = 0 %then %do;
248                        %put NOTE: Creating directory &dac_sas_dir;
249                        %let _rc = %sysfunc(dcreate(DAC_SAS, &outdir));
250                        %if &_rc = %then %do;
251                            %put ERROR: Failed to create directory &dac_sas_dir;
252                            %abort;
253                        %end;
254                    %end;
255                    %else %do;
256                        %put NOTE: Directory &dac_sas_dir already exists.;
257                    %end;
258        
259                    libname _inlib  "&indir";
260                    libname _outdac "&dac_sas_dir";
261        
262                    /* Copy each SAS dataset to DAC_SAS, renaming those with suffixes.
263                       Strategy: copy to DAC_SAS with original name, then rename the
264                       copy in DAC_SAS to the standard name.  The original input files
265                       are never modified. */
266                    data _null_;
267                        set _work_sas;
268                        length dsname_lc $32 std_lc $32;
269                        dsname_lc = lowcase(dsname);
270                        std_lc    = lowcase(standard_name);
271        
272                        /* Copy dataset to DAC_SAS */
273                        call execute(
274                            'proc copy in=_inlib out=_outdac memtype=data; select ' ||
275                            strip(dsname_lc) || '; run;'
276                        );
277        
278                        /* Rename the copy in DAC_SAS if a suffix was present */
279                        if needs_rename then do;
280                            call execute(
281                                'proc datasets library=_outdac nolist; change ' ||
282                                strip(dsname_lc) || '=' || strip(std_lc) || '; quit;'
283                            );
284                        end;
285                    run;
286        
287                    libname _inlib  clear;
288                    libname _outdac clear;
289        
290                    %put NOTE: SAS dataset standardization complete.;
291                    %put NOTE: Standardized SAS files are in: &dac_sas_dir;
292        
293                %end; /* sas_rename_count > 0 after dedup */
294        
295            %end; /* sas_total > 0 and sas_rename_count > 0 */
