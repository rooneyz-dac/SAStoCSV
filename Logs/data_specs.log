129            /**Save current options to reset after macro runs**/
130            %local _mergenoby _notes _quotelenmax _starttime _listing;
131            %let _starttime=%sysfunc(time());
132            %let _notes=%sysfunc(getoption(notes));
133            %let _mergenoby=%sysfunc(getoption(mergenoby));
134            %let _quotelenmax=%sysfunc(getoption(quotelenmax));
