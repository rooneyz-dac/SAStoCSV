264                /**Check if values are in approved list**/
265                %do _z=1 %to %sysfunc(countw(&parmlist,|,m));
266                    %if %qupcase(%superq(&parm))=%qupcase(%scan(&parmlist,&_z,|,m)) %then %let
266      ! _test=1;
