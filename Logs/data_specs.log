147            %if &pipe_pos > 0 %then %do;
148                %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
149                %local remaining pipe2_pos;
150                %let remaining = %substr(&sysparm_value, %eval(&pipe_pos + 1));
151        
152                /* Check for additional pipe-separated optional parameters */
153                %let pipe2_pos = %sysfunc(findc(&remaining, |));
154                %if &pipe2_pos > 0 %then %do;
155                    %let outdir = %substr(&remaining, 1, %eval(&pipe2_pos - 1));
156                    %local extra_params ep_count ep_i ep_curr ep_name eq_pos ep_value;
157                    %let extra_params = %substr(&remaining, %eval(&pipe2_pos + 1));
158                    %let ep_count = %sysfunc(countw(&extra_params, |));
159                    %do ep_i = 1 %to &ep_count;
160                        %let ep_curr = %scan(&extra_params, &ep_i, |);
161                        %let eq_pos = %sysfunc(findc(&ep_curr, =));
162                        %if &eq_pos > 0 %then %do;
163                            %let ep_name = %qupcase(%substr(&ep_curr, 1, %eval(&eq_pos - 1)));
