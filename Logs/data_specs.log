167                                %let ep_value = ;
168                            %if &ep_name = INDEX %then %let index = &ep_value;
169                            %else %if &ep_name = CAT_THRESHOLD %then %do;
170                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let cat_threshold
170      !  = &ep_value;
171                            %end;
