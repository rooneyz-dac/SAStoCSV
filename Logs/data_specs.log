139            /**Parse SYSPARM for input and output paths**/
140            %local sysparm_value indir outdir pipe_pos;
141            %let sysparm_value = &sysparm;
142            %put DEBUG: Raw SYSPARM value = &sysparm_value;
143        
144            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
145            %put DEBUG: Pipe position = &pipe_pos;
146        
147            %if &pipe_pos > 0 %then %do;
148                %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
149                %local remaining pipe2_pos;
150                %let remaining = %substr(&sysparm_value, %eval(&pipe_pos + 1));
151        
152                /* Check for additional pipe-separated optional parameters */
153                %let pipe2_pos = %sysfunc(findc(&remaining, |));
154                %if &pipe2_pos > 0 %then %do;
155                    %let outdir = %substr(&remaining, 1, %eval(&pipe2_pos - 1));
156                    %local extra_params ep_count ep_i ep_curr ep_name eq_pos ep_value;
157                    %let extra_params = %substr(&remaining, %eval(&pipe2_pos + 1));
158                    %let ep_count = %sysfunc(countw(&extra_params, |));
159                    %do ep_i = 1 %to &ep_count;
160                        %let ep_curr = %scan(&extra_params, &ep_i, |);
161                        %let eq_pos = %sysfunc(findc(&ep_curr, =));
162                        %if &eq_pos > 0 %then %do;
163                            %let ep_name = %qupcase(%substr(&ep_curr, 1, %eval(&eq_pos - 1)));
164                            %let ep_value = %substr(&ep_curr, %eval(&eq_pos + 1));
165                            %if &ep_name = INDEX %then %let index = &ep_value;
166                            %else %if &ep_name = CAT_THRESHOLD %then %do;
167                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let cat_threshold
167      !  = &ep_value;
168                            %end;
169                            %else %if &ep_name = FORMAT %then %do;
170                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let format =
170      ! &ep_value;
171                            %end;
172                            %else %if &ep_name = ORDER %then %do;
173                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let order =
173      ! &ep_value;
174                            %end;
175                            %else %if &ep_name = WHERE %then %let where = &ep_value;
176                            %else %if &ep_name = DEBUG %then %do;
177                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let debug =
177      ! &ep_value;
178                            %end;
179                        %end;
180                    %end;
181                    %put DEBUG: Parsed extra params: index=&index cat_threshold=&cat_threshold
181      ! format=&format order=&order debug=&debug;
182                %end;
183                %else %do;
184                    %let outdir = &remaining;
185                %end;
186            %end;
187            %else %do;
