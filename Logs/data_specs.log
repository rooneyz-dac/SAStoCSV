173                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let format =
173      ! &ep_value;
174                            %end;
175                            %else %if &ep_name = ORDER %then %do;
176                                %if %sysevalf(%superq(ep_value)^=,boolean) %then %let order =
