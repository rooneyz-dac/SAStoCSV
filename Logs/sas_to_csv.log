94         /* 3) Create output folder if it does not exist */
95         options noxwait noxsync;
96         data _null_;
97             length out $260 parent $260;
98             out = "&out_dir";
99         
100            /* Remove trailing backslash if present */
101            if substr(out, length(out), 1) = '\' then
102                out = substr(out, 1, length(out) - 1);
103        
104            /* Get parent directory for dcreate */
105            pos = length(out) - index(reverse(out), '\') + 1;
106            if pos > 0 and pos < length(out) then do;
107                parent = substr(out, 1, pos - 1);
108                folder = substr(out, pos + 1);
109                rc = dcreate(folder, parent);
110            end;
111            else do;
112                rc = dcreate(out, '');
113            end;
114        
115            if rc = '' then put "NOTE: Directory &out_dir already exists or created successfully.";
116            else put "ERROR: Could not create directory &out_dir";
117        run;

