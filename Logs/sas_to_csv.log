94         /* 3) Create output folder if it does not exist */
95         options noxwait noxsync;
96         data _null_;
97             length out $260 parent $260 rc $260;
98             out = "&out_dir";
99         
100            /* Remove trailing backslash if present */
101            if substr(out, length(out), 1) = '\' then
102                out = substr(out, 1, length(out) - 1);
103        
104            if fileexist(out) then
105                put "NOTE: Directory &out_dir already exists.";
106            else do;
107                /* Get parent directory for dcreate */
108                pos = length(out) - index(reverse(out), '\') + 1;
109                if pos > 0 and pos < length(out) then do;
110                    parent = substr(out, 1, pos - 1);
111                    folder = substr(out, pos + 1);
112                    rc = dcreate(folder, parent);
113                end;
114                else do;
115                    rc = dcreate(out, '');
116                end;
117        
118                if rc ne '' then put "NOTE: Created directory &out_dir successfully.";
119                else put "ERROR: Could not create directory &out_dir";
120            end;
121        run;

