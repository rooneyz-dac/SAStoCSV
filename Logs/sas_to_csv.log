138        /* 6) Macro to export all datasets to CSV in csv_dir */
139        %macro export_all_to_csv;
140            %local n i dsname;
141            proc sql noprint;
142                select count(*) into :n trimmed from work._dslist;
143            quit;
144        
145            %if &n = 0 %then %do;
146                %put NOTE: No SAS datasets found in &in_dir;
147                %return;
148            %end;
149        
150            %do i = 1 %to &n;
151                proc sql noprint;
152                    select memname into :dsname trimmed
153                    from work._dslist
154                    where monotonic() = &i;
155                quit;
156                %let csvfile = &csv_dir.\&dsname..csv;
157                %put NOTE: Exporting INLIB.&dsname to &csvfile;
158                proc export data=inlib.&dsname
159                    outfile="&csvfile"
160                    dbms=csv
161                    replace;
162                run;
163            %end;
164        %mend export_all_to_csv;
