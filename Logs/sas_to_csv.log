146        
147        /* 6) Macro to export all datasets to CSV in csv_dir */
148        %macro export_all_to_csv;
149            %local n i dsname;
150            proc sql noprint;
151                select count(*) into :n trimmed from work._dslist;
152            quit;
153        
154            %if &n = 0 %then %do;
155                %put NOTE: No SAS datasets found in &in_dir;
156                %return;
157            %end;
158        
159            %do i = 1 %to &n;
160                proc sql noprint;
161                    select memname into :dsname trimmed
162                    from work._dslist
163                    where monotonic() = &i;
164                quit;
5                                           The SAS System              16:21 Thursday, March 26, 2026

165                %let csvfile = &csv_dir.\&dsname..csv;
166                %put NOTE: Exporting INLIB.&dsname to &csvfile;
167                proc export data=inlib.&dsname
168                    outfile="&csvfile"
169                    dbms=csv
170                    replace;
171                run;
172            %end;
173        %mend export_all_to_csv;
174        
175        %export_all_to_csv;
