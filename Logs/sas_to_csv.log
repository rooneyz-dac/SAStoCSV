1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoCSVcli20260320.sas
3          | SHORT DESC   : Batch converts all SAS datasets in a directory to
4          |                CSV format via command-line interface
5          *------------------------------------------------------------------*
6          | CREATED BY   : Modified for CLI usage
7          | DATE CREATED : 2025-11-21
8          *------------------------------------------------------------------*
9          | VERSION UPDATES:
10         | 2025-11-21: Initial CLI release
11         |   - Added SYSPARM parsing for input and output directories
12         |   - Added automatic creation of DAC_CSV output subfolder
13         |   - Added error log generation
14         *------------------------------------------------------------------*
15         | PURPOSE
16         | Exports all SAS datasets (.sas7bdat) found in a specified input
17         | directory to CSV format. Output CSV files are placed in a
18         | DAC_CSV subfolder within the specified output directory. An error
19         | log file (error_log.txt) is written to the output directory upon
20         | completion summarizing any SAS errors encountered.
21         |
22         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
23         | INPUT_DIRECTORY  = Path to the folder containing .sas7bdat files
24         |                    to be converted
25         | OUTPUT_DIRECTORY = Path to the folder where the DAC_CSV subfolder
26         |                    and error log will be created
27         |
28         | 2.0: OPTIONAL PARAMETERS
29         | None. All parameters are supplied via SYSPARM.
30         |
31         | USAGE:
32         |   sas -sysparm "input_directory|output_directory"
2                                           The SAS System                16:55 Friday, March 20, 2026

33         |       -sysin SAStoCSVcli20260320.sas
34         |
35         | OUTPUT STRUCTURE:
36         |   output_directory\
37         |   ├── DAC_CSV\          - CSV exports of all SAS datasets
38         |   └── error_log.txt     - Error summary from the SAS run
39         *------------------------------------------------------------------*
40         | OPERATING SYSTEM COMPATIBILITY
41         | SAS v9.4 or Higher: Yes
42         *------------------------------------------------------------------*
43         | MACRO CALL
44         |
45         | Not applicable. Script is invoked directly via the SAS command
46         | line using -sysin and -sysparm.
47         *------------------------------------------------------------------*
48         | EXAMPLES
49         |
50         | Basic usage:
51         |   sas -sysparm "C:\data\input|C:\data\output"
52         |       -sysin SAStoCSVcli20260320.sas
53         |
54         | Using a study-specific output folder:
55         |   sas -sysparm "C:\studies\trial1\sas|C:\studies\trial1\output"
56         |       -sysin SAStoCSVcli20260320.sas
57         *------------------------------------------------------------------*/
58         
59         /* 1) Parse SYSPARM to get input and output directories */
60         %let params = %sysfunc(dequote(&SYSPARM));
61         
62         %if %length(&params) = 0 %then %do;
63             %put ERROR: SYSPARM not provided. You must specify input and output directories.;
64             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
64       ! "C:\path\to\data|C:\path\to\output";
65             %abort cancel;
66         %end;
67         
68         /* Split SYSPARM by pipe delimiter */
69         %let in_dir = %scan(&params, 1, |);
70         %let out_dir = %scan(&params, 2, |);
71         
72         %if %length(&in_dir) = 0 %then %do;
73             %put ERROR: Input directory not provided in SYSPARM.;
74             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
74       ! "C:\path\to\data|C:\path\to\output";
75             %abort cancel;
76         %end;
77         
78         %if %length(&out_dir) = 0 %then %do;
79             %put ERROR: Output directory not provided in SYSPARM.;
80             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
80       ! "C:\path\to\data|C:\path\to\output";
81             %abort cancel;
82         %end;
