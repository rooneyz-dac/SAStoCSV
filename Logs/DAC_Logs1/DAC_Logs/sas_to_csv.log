153        
154        /* 6) Macro to export all datasets to CSV in csv_dir */
155        %macro export_all_to_csv;
156            %local n i dsname;
157            proc sql noprint;
158                select count(*) into :n trimmed from work._dslist;
159            quit;
160        
161            %if &n = 0 %then %do;
162                %put NOTE: No SAS datasets found in &in_dir;
163                %return;
164            %end;
165        
166            %do i = 1 %to &n;
167                proc sql noprint;
168                    select memname into :dsname trimmed
169                    from work._dslist
170                    where monotonic() = &i;
171                quit;
172                %let csvfile = &csv_dir.\&dsname..csv;
173                %put NOTE: Exporting INLIB.&dsname to &csvfile;
174                proc export data=inlib.&dsname
175                    outfile="&csvfile"
176                    dbms=csv
177                    replace;
178                run;
179            %end;
180        %mend export_all_to_csv;
181        
182        %export_all_to_csv;
