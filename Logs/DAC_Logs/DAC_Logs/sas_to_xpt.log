1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoXPTcli20260320.sas
3          | SHORT DESC   : Bidirectional batch conversion between SAS7BDAT
4          |                and XPT (SAS Transport) formats via CLI
5          *------------------------------------------------------------------*
6          | CREATED BY   : DAC Development Team
7          | DATE CREATED : 2025-11-21
8          | VERSION      : 2.0
9          *------------------------------------------------------------------*
10         | VERSION UPDATES:
11         | 2025-11-21: Initial CLI release (v2.0)
12         |   - Added SYSPARM parsing for input and output directories
13         |   - Added bidirectional conversion (SAS7BDAT <-> XPT)
14         |   - Added automatic creation of DAC_XPT and DAC_SDTM subfolders
15         |   - Added conversion error log generation
16         | 2026-03-20: File standardized to 20260320 naming convention
17         |   - No functional changes; header and filename updated to match
18         |     the pipeline versioning convention used across all CLI scripts
19         *------------------------------------------------------------------*
20         | PURPOSE
21         | Performs batch bidirectional conversion of SAS datasets between
22         | SAS7BDAT and XPT (SAS Transport) formats. When .sas7bdat files
23         | are detected in the input directory they are converted to .xpt
24         | and placed in OUTDIR\DAC_XPT. When .xpt files are detected they
25         | are converted to .sas7bdat and placed in OUTDIR\DAC_SDTM. Both
26         | conversion types may occur in a single run. An error log
27         | (xpt_error_log.txt) is written to the output directory.
28         |
29         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
30         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
31         |                    files to be converted
32         | OUTPUT_DIRECTORY = Path to folder where output subfolders and
2                                           The SAS System                  15:33 Monday, May 18, 2026

33         |                    the error log will be created. Must exist
34         |                    prior to execution.
35         |
36         | 2.0: XPT FORMAT LIMITATIONS
37         | MEMBER NAMES     = Limited to 8 characters by the XPT format
38         |                    specification. Dataset names longer than 8
39         |                    characters are automatically truncated to the
40         |                    first 4 characters concatenated with the last
41         |                    4 characters.
42         |                    Example: "berkeley_pbo_ae" becomes "berkl_ae"
43         |
44         | USAGE:
45         |   sas -sysparm "input_directory|output_directory"
46         |       -sysin SAStoXPTcli20260320.sas
47         |
48         | OUTPUT STRUCTURE:
49         |   output_directory\
50         |   ├── DAC_XPT\          - XPT exports (from .sas7bdat input)
51         |   ├── DAC_SDTM\         - SAS7BDAT exports (from .xpt input)
52         |   └── xpt_error_log.txt - Conversion activity and error log
53         *------------------------------------------------------------------*
54         | OPERATING SYSTEM COMPATIBILITY
55         | SAS v9.4 or Higher: Yes
56         | Windows:            Yes (uses DIR command for file listing)
57         *------------------------------------------------------------------*
58         | MACRO CALL
59         |
60         | Not applicable. Script is invoked directly via the SAS command
61         | line using -sysin and -sysparm.
62         *------------------------------------------------------------------*
63         | EXAMPLES
64         |
65         | Convert SAS datasets to XPT format:
66         |   sas -sysparm "C:\data\input|C:\data\output"
67         |       -sysin SAStoXPTcli20260320.sas
68         |
69         | Convert XPT files back to SAS7BDAT:
70         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
71         |       -sysin SAStoXPTcli20260320.sas
72         |
73         | Process a mixed directory (both .sas7bdat and .xpt present):
74         |   sas -sysparm "C:\data\mixed|C:\data\output"
75         |       -sysin SAStoXPTcli20260320.sas
76         *------------------------------------------------------------------*/
77         
78         %macro convert_files;
79             %let sysparm_value = &sysparm;
80             %put DEBUG: Raw SYSPARM value = &sysparm_value;
81         
82             %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
83             %put DEBUG: Pipe position = &pipe_pos;
84         
85             %if &pipe_pos > 0 %then %do;
86                 %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
3                                           The SAS System                  15:33 Monday, May 18, 2026

87                 %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
88             %end;
89             %else %do;
90                 %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
91                 %abort;
92             %end;
93         
94             %put DEBUG: Input Directory = &indir;
95             %put DEBUG: Output Directory = &outdir;
96         
97             %let indir_exist = %sysfunc(fileexist(&indir));
98             %let outdir_exist = %sysfunc(fileexist(&outdir));
99         
100            %if &indir_exist = 0 %then %do;
101                %put ERROR: Input directory does not exist: &indir;
102                %abort;
103            %end;
104        
105            %if &outdir_exist = 0 %then %do;
106                %put ERROR: Output directory does not exist: &outdir;
107                %abort;
108            %end;
109        
110            %let errlog = &outdir\xpt_error_log.txt;
111        
112            data _null_;
113                file "&errlog";
114                length dt $19;
115                dt = put(datetime(), datetime19.);
116                put "Error Log - " dt;
117                put "Input Directory: &indir";
118                put "Output Directory: &outdir";
119                put "----------------------------------------";
120            run;
121        
122            filename infiles pipe "dir /b ""&indir\*.sas7bdat"" ""&indir\*.xpt"" 2>nul";
123        
124            data file_list;
125                infile infiles truncover;
126                input filename $256.;
127                length filetype $10;
128                if index(upcase(filename), '.SAS7BDAT') > 0 then filetype = 'SAS7BDAT';
129                else if index(upcase(filename), '.XPT') > 0 then filetype = 'XPT';
130            run;
131        
132            filename infiles clear;
133        
134            proc sql noprint;
135                select count(*) into :sas7bdat_count trimmed from file_list where filetype =
135      ! 'SAS7BDAT';
136                select count(*) into :xpt_count trimmed from file_list where filetype = 'XPT';
137            quit;
138        
139            %put DEBUG: Found &sas7bdat_count SAS7BDAT files;
4                                           The SAS System                  15:33 Monday, May 18, 2026

140            %put DEBUG: Found &xpt_count XPT files;
141        
142            %if &sas7bdat_count > 0 %then %do;
143                %let xpt_dir = &outdir\DAC_XPT;
144                %let xpt_exist = %sysfunc(fileexist(&xpt_dir));
145        
146                %if &xpt_exist = 0 %then %do;
147                    %put DEBUG: Creating directory &xpt_dir;
148                    %let rc = %sysfunc(dcreate(DAC_XPT, &outdir));
149                    %if &rc = %then %do;
150                        %put ERROR: Failed to create directory &xpt_dir;
151                        %abort;
152                    %end;
153                %end;
154        
155                libname inlib "&indir";
156        
157                data _null_;
158                    set file_list end=eof;
159                    where filetype = 'SAS7BDAT';
160        
161                    length dsname memname $32 xpt_path $256;
162        
163                    dsname = scan(filename, 1, '.');
164        
165                    /* Truncate to first 4 + last 4 characters for XPT compliance */
166                    if length(dsname) > 8 then
167                        memname = substr(dsname, 1, 4) || substr(dsname, length(dsname) - 3, 4);
168                    else
169                        memname = dsname;
170        
171                    xpt_path = "&xpt_dir\" || strip(memname) || ".xpt";
172        
173                    call execute('libname xptlib xport "' || strip(xpt_path) || '";');
174        
175                    /* Use PROC DATASETS to rename, then PROC COPY to transfer */
176                    if dsname ne memname then do;
177                        call execute('proc datasets library=inlib nolist; change ' || strip(dsname)
177      !  || '=' || strip(memname) || '; quit;');
178                    end;
179        
180                    call execute('proc copy in=inlib out=xptlib memtype=data; select ' ||
180      ! strip(memname) || '; run;');
181        
182                    /* Rename back if needed */
183                    if dsname ne memname then do;
184                        call execute('proc datasets library=inlib nolist; change ' ||
184      ! strip(memname) || '=' || strip(dsname) || '; quit;');
185                    end;
186        
187                    call execute('libname xptlib clear;');
188        
189                    file "&errlog" mod;
190                    put "Converted to XPT: " dsname " -> " memname " (" xpt_path ")";
5                                           The SAS System                  15:33 Monday, May 18, 2026

191        
192                    if eof then do;
193                        put "----------------------------------------";
194                        put "Total SAS7BDAT files processed: " _n_;
195                    end;
196                run;
197        
198                libname inlib clear;
199            %end;
200        
201            %if &xpt_count > 0 %then %do;
202                %let sdtm_dir = &outdir\DAC_SDTM;
203                %let sdtm_exist = %sysfunc(fileexist(&sdtm_dir));
204        
205                %if &sdtm_exist = 0 %then %do;
206                    %put DEBUG: Creating directory &sdtm_dir;
207                    %let rc = %sysfunc(dcreate(DAC_SDTM, &outdir));
208                    %if &rc = %then %do;
209                        %put ERROR: Failed to create directory &sdtm_dir;
210                        %abort;
211                    %end;
212                %end;
213        
214                libname outsdtm "&sdtm_dir";
215        
216                data _null_;
217                    set file_list end=eof;
218                    where filetype = 'XPT';
219        
220                    length dsname $32;
221        
222                    dsname = scan(filename, 1, '.');
223        
224                    call execute('libname xptlib xport "' || "&indir\" || strip(filename) || '";');
225                    call execute('proc copy in=xptlib out=outsdtm; run;');
226                    call execute('libname xptlib clear;');
227        
228                    file "&errlog" mod;
229                    put "Converted to SAS7BDAT: " dsname;
230        
231                    if eof then do;
232                        put "----------------------------------------";
233                        put "Total XPT files processed: " _n_;
234                    end;
235                run;
236        
237                libname outsdtm clear;
238            %end;
239        
240            %put DEBUG: Conversion process completed;
241        
242            data _null_;
243                file "&errlog" mod;
244                length dt $19;
6                                           The SAS System                  15:33 Monday, May 18, 2026

245                dt = put(datetime(), datetime19.);
246                put "----------------------------------------";
247                put "Process completed: " dt;
248            run;
249        
250        %mend convert_files;
251        
252        %convert_files;
