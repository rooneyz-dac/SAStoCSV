1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoXPTcli20260320.sas
3          | SHORT DESC   : Bidirectional batch conversion between SAS7BDAT
4          |                and XPT (SAS Transport) formats via CLI
5          *------------------------------------------------------------------*
6          | CREATED BY   : DAC Development Team
7          | DATE CREATED : 2025-11-21
8          | VERSION      : 2.1
9          *------------------------------------------------------------------*
10         | VERSION UPDATES:
11         | 2025-11-21: Initial CLI release (v2.0)
12         |   - Added SYSPARM parsing for input and output directories
13         |   - Added bidirectional conversion (SAS7BDAT <-> XPT)
14         |   - Added automatic creation of DAC_XPT and DAC_SDTM subfolders
15         |   - Added conversion error log generation
16         | 2026-03-20: File standardized to 20260320 naming convention
17         |   - No functional changes; header and filename updated to match
18         |     the pipeline versioning convention used across all CLI scripts
19         | 2026-05-19: Fixed dcreate return-value check (v2.1)
20         |   - Replaced `%if &rc = %then` with `%if %length(&rc) = 0 %then`
21         |     for all three directory-creation guards (DAC_Logs, DAC_XPT,
22         |     DAC_SDTM). dcreate returns the new directory name (a string)
23         |     on success, causing %EVAL to abort with "character operand
24         |     found where numeric operand required" when the %if condition
25         |     tried to compare that string numerically. Using %length()
26         |     correctly detects an empty return value (failure) without
27         |     triggering a numeric-evaluation error.
28         *------------------------------------------------------------------*
29         | PURPOSE
30         | Performs batch bidirectional conversion of SAS datasets between
31         | SAS7BDAT and XPT (SAS Transport) formats. When .sas7bdat files
32         | are detected in the input directory they are converted to .xpt
2                                           The SAS System               11:43 Wednesday, May 20, 2026

33         | and placed in OUTDIR\DAC_XPT. When .xpt files are detected they
34         | are converted to .sas7bdat and placed in OUTDIR\DAC_SDTM. Both
35         | conversion types may occur in a single run. An error log
36         | (xpt_error_log.txt) is written to the DAC_Logs subdirectory.
37         |
38         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
39         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
40         |                    files to be converted
41         | OUTPUT_DIRECTORY = Path to folder where output subfolders and
42         |                    the error log will be created. Must exist
43         |                    prior to execution.
44         |
45         | 2.0: XPT FORMAT LIMITATIONS
46         | MEMBER NAMES     = Limited to 8 characters by the XPT format
47         |                    specification. Dataset names longer than 8
48         |                    characters are automatically truncated to the
49         |                    first 4 characters concatenated with the last
50         |                    4 characters.
51         |                    Example: "berkeley_pbo_ae" becomes "berkl_ae"
52         |
53         | USAGE:
54         |   sas -sysparm "input_directory|output_directory"
55         |       -sysin SAStoXPTcli20260320.sas
56         |
57         | OUTPUT STRUCTURE:
58         |   output_directory\
59         |   ├── DAC_XPT\          - XPT exports (from .sas7bdat input)
60         |   ├── DAC_SDTM\         - SAS7BDAT exports (from .xpt input)
61         |   └── DAC_Logs\
62         |       └── xpt_error_log.txt - Conversion activity and error log
63         *------------------------------------------------------------------*
64         | OPERATING SYSTEM COMPATIBILITY
65         | SAS v9.4 or Higher: Yes
66         | Windows:            Yes (uses DIR command for file listing)
67         *------------------------------------------------------------------*
68         | MACRO CALL
69         |
70         | Not applicable. Script is invoked directly via the SAS command
71         | line using -sysin and -sysparm.
72         *------------------------------------------------------------------*
73         | EXAMPLES
74         |
75         | Convert SAS datasets to XPT format:
76         |   sas -sysparm "C:\data\input|C:\data\output"
77         |       -sysin SAStoXPTcli20260320.sas
78         |
79         | Convert XPT files back to SAS7BDAT:
80         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
81         |       -sysin SAStoXPTcli20260320.sas
82         |
83         | Process a mixed directory (both .sas7bdat and .xpt present):
84         |   sas -sysparm "C:\data\mixed|C:\data\output"
85         |       -sysin SAStoXPTcli20260320.sas
86         *------------------------------------------------------------------*/
3                                           The SAS System               11:43 Wednesday, May 20, 2026

87         
88         %macro convert_files;
89             %let sysparm_value = &sysparm;
90             %put DEBUG: Raw SYSPARM value = &sysparm_value;
91         
92             %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
93             %put DEBUG: Pipe position = &pipe_pos;
94         
95             %if &pipe_pos > 0 %then %do;
96                 %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
97                 %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
98             %end;
99             %else %do;
100                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
101                %abort;
102            %end;
103        
104            %put DEBUG: Input Directory = &indir;
105            %put DEBUG: Output Directory = &outdir;
106        
107            %let indir_exist = %sysfunc(fileexist(&indir));
108            %let outdir_exist = %sysfunc(fileexist(&outdir));
109        
110            %if &indir_exist = 0 %then %do;
111                %put ERROR: Input directory does not exist: &indir;
112                %abort;
113            %end;
114        
115            %if &outdir_exist = 0 %then %do;
116                %put ERROR: Output directory does not exist: &outdir;
117                %abort;
118            %end;
119        
120            /* Create DAC_Logs subfolder if it does not exist */
121            %let dac_logs_dir = &outdir\DAC_Logs;
122            %let dac_logs_exist = %sysfunc(fileexist(&dac_logs_dir));
123            %if &dac_logs_exist = 0 %then %do;
124                %let rc = %sysfunc(dcreate(DAC_Logs, &outdir));
125                %if %length(&rc) = 0 %then %do;
126                    %put ERROR: Failed to create directory &dac_logs_dir;
127                    %abort;
128                %end;
129            %end;
130        
131            %let errlog = &outdir\DAC_Logs\xpt_error_log.txt;
132        
133            data _null_;
134                file "&errlog";
135                length dt $19;
136                dt = put(datetime(), datetime19.);
137                put "Error Log - " dt;
138                put "Input Directory: &indir";
139                put "Output Directory: &outdir";
140                put "----------------------------------------";
4                                           The SAS System               11:43 Wednesday, May 20, 2026

141            run;
142        
143            filename infiles pipe "dir /b ""&indir\*.sas7bdat"" ""&indir\*.xpt"" 2>nul";
144        
145            data file_list;
146                infile infiles truncover;
147                input filename $256.;
148                length filetype $10;
149                if index(upcase(filename), '.SAS7BDAT') > 0 then filetype = 'SAS7BDAT';
150                else if index(upcase(filename), '.XPT') > 0 then filetype = 'XPT';
151            run;
152        
153            filename infiles clear;
154        
155            proc sql noprint;
156                select count(*) into :sas7bdat_count trimmed from file_list where filetype =
156      ! 'SAS7BDAT';
157                select count(*) into :xpt_count trimmed from file_list where filetype = 'XPT';
158            quit;
159        
160            %put DEBUG: Found &sas7bdat_count SAS7BDAT files;
161            %put DEBUG: Found &xpt_count XPT files;
162        
163            %if &sas7bdat_count > 0 %then %do;
164                %let xpt_dir = &outdir\DAC_XPT;
165                %let xpt_exist = %sysfunc(fileexist(&xpt_dir));
166        
167                %if &xpt_exist = 0 %then %do;
168                    %put DEBUG: Creating directory &xpt_dir;
169                    %let rc = %sysfunc(dcreate(DAC_XPT, &outdir));
170                    %if %length(&rc) = 0 %then %do;
171                        %put ERROR: Failed to create directory &xpt_dir;
172                        %abort;
173                    %end;
174                %end;
175        
176                libname inlib "&indir";
177        
178                data _null_;
179                    set file_list end=eof;
180                    where filetype = 'SAS7BDAT';
181        
182                    length dsname memname $32 xpt_path $256;
183        
184                    dsname = scan(filename, 1, '.');
185        
186                    /* Truncate to first 4 + last 4 characters for XPT compliance */
187                    if length(dsname) > 8 then
188                        memname = substr(dsname, 1, 4) || substr(dsname, length(dsname) - 3, 4);
189                    else
190                        memname = dsname;
191        
192                    xpt_path = "&xpt_dir\" || strip(memname) || ".xpt";
193        
5                                           The SAS System               11:43 Wednesday, May 20, 2026

194                    call execute('libname xptlib xport "' || strip(xpt_path) || '";');
195        
196                    /* Use PROC DATASETS to rename, then PROC COPY to transfer */
197                    if dsname ne memname then do;
198                        call execute('proc datasets library=inlib nolist; change ' || strip(dsname)
198      !  || '=' || strip(memname) || '; quit;');
199                    end;
200        
201                    call execute('proc copy in=inlib out=xptlib memtype=data; select ' ||
201      ! strip(memname) || '; run;');
202        
203                    /* Rename back if needed */
204                    if dsname ne memname then do;
205                        call execute('proc datasets library=inlib nolist; change ' ||
205      ! strip(memname) || '=' || strip(dsname) || '; quit;');
206                    end;
207        
208                    call execute('libname xptlib clear;');
209        
210                    file "&errlog" mod;
211                    put "Converted to XPT: " dsname " -> " memname " (" xpt_path ")";
212        
213                    if eof then do;
214                        put "----------------------------------------";
215                        put "Total SAS7BDAT files processed: " _n_;
216                    end;
217                run;
218        
219                libname inlib clear;
220            %end;
221        
222            %if &xpt_count > 0 %then %do;
223                %let sdtm_dir = &outdir\DAC_SDTM;
224                %let sdtm_exist = %sysfunc(fileexist(&sdtm_dir));
225        
226                %if &sdtm_exist = 0 %then %do;
227                    %put DEBUG: Creating directory &sdtm_dir;
228                    %let rc = %sysfunc(dcreate(DAC_SDTM, &outdir));
229                    %if %length(&rc) = 0 %then %do;
230                        %put ERROR: Failed to create directory &sdtm_dir;
231                        %abort;
232                    %end;
233                %end;
234        
235                libname outsdtm "&sdtm_dir";
236        
237                data _null_;
238                    set file_list end=eof;
239                    where filetype = 'XPT';
240        
241                    length dsname $32;
242        
243                    dsname = scan(filename, 1, '.');
244        
6                                           The SAS System               11:43 Wednesday, May 20, 2026

245                    call execute('libname xptlib xport "' || "&indir\" || strip(filename) || '";');
246                    call execute('proc copy in=xptlib out=outsdtm; run;');
247                    call execute('libname xptlib clear;');
248        
249                    file "&errlog" mod;
250                    put "Converted to SAS7BDAT: " dsname;
251        
252                    if eof then do;
253                        put "----------------------------------------";
254                        put "Total XPT files processed: " _n_;
255                    end;
256                run;
257        
258                libname outsdtm clear;
259            %end;
260        
261            %put DEBUG: Conversion process completed;
262        
263            data _null_;
264                file "&errlog" mod;
265                length dt $19;
266                dt = put(datetime(), datetime19.);
267                put "----------------------------------------";
268                put "Process completed: " dt;
269            run;
270        
271        %mend convert_files;
272        
273        %convert_files;
