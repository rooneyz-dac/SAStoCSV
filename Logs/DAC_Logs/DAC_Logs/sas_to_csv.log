126        /* 3a) Create DAC_CSV subfolder */
127        data _null_;
128            length rc $260;
129            if fileexist("&csv_dir") then
130                put "NOTE: Directory &csv_dir already exists.";
131            else do;
132                rc = dcreate('DAC_CSV', "&out_dir");
133                if rc ne '' then put "NOTE: Created directory &csv_dir successfully.";
134                else put "ERROR: Could not create directory &csv_dir";
135            end;
136        run;

