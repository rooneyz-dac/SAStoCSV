1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : SAStoCSVcli20260320.sas
3          | SHORT DESC   : Batch converts all SAS datasets in a directory to
4          |                CSV format via command-line interface
5          *------------------------------------------------------------------*
6          | CREATED BY   : DAC Development Team
7          | DATE CREATED : 2025-11-21
8          *------------------------------------------------------------------*
9          | VERSION UPDATES:
10         | 2025-11-21: Initial CLI release
11         |   - Added SYSPARM parsing for input and output directories
12         |   - Added automatic creation of DAC_CSV output subfolder
13         |   - Added error log generation
14         | 2026-03-20: File standardized to 20260320 naming convention
15         |   - No functional changes; header and filename updated to match
16         |     the pipeline versioning convention used across all CLI scripts
17         *------------------------------------------------------------------*
18         | PURPOSE
19         | Exports all SAS datasets (.sas7bdat) found in a specified input
20         | directory to CSV format. Output CSV files are placed in a
21         | DAC_CSV subfolder within the specified output directory. An error
22         | log file (error_log.txt) is written to the output directory upon
23         | completion summarizing any SAS errors encountered.
24         |
25         | 1.0: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
26         | INPUT_DIRECTORY  = Path to the folder containing .sas7bdat files
27         |                    to be converted
28         | OUTPUT_DIRECTORY = Path to the folder where the DAC_CSV subfolder
29         |                    and error log will be created
30         |
31         | 2.0: OPTIONAL PARAMETERS
32         | None. All parameters are supplied via SYSPARM.
2                                           The SAS System                  15:33 Monday, May 18, 2026

33         |
34         | USAGE:
35         |   sas -sysparm "input_directory|output_directory"
36         |       -sysin SAStoCSVcli20260320.sas
37         |
38         | OUTPUT STRUCTURE:
39         |   output_directory\
40         |   ├── DAC_CSV\          - CSV exports of all SAS datasets
41         |   └── error_log.txt     - Error summary from the SAS run
42         *------------------------------------------------------------------*
43         | OPERATING SYSTEM COMPATIBILITY
44         | SAS v9.4 or Higher: Yes
45         *------------------------------------------------------------------*
46         | MACRO CALL
47         |
48         | Not applicable. Script is invoked directly via the SAS command
49         | line using -sysin and -sysparm.
50         *------------------------------------------------------------------*
51         | EXAMPLES
52         |
53         | Basic usage:
54         |   sas -sysparm "C:\data\input|C:\data\output"
55         |       -sysin SAStoCSVcli20260320.sas
56         |
57         | Using a study-specific output folder:
58         |   sas -sysparm "C:\studies\trial1\sas|C:\studies\trial1\output"
59         |       -sysin SAStoCSVcli20260320.sas
60         *------------------------------------------------------------------*/
61         
62         /* 1) Parse SYSPARM to get input and output directories */
63         %let params = %sysfunc(dequote(&SYSPARM));
64         
65         %if %length(&params) = 0 %then %do;
66             %put ERROR: SYSPARM not provided. You must specify input and output directories.;
67             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
67       ! "C:\path\to\data|C:\path\to\output";
68             %abort cancel;
69         %end;
70         
71         /* Split SYSPARM by pipe delimiter */
72         %let in_dir = %scan(&params, 1, |);
73         %let out_dir = %scan(&params, 2, |);
74         
75         %if %length(&in_dir) = 0 %then %do;
76             %put ERROR: Input directory not provided in SYSPARM.;
77             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
77       ! "C:\path\to\data|C:\path\to\output";
78             %abort cancel;
79         %end;
80         
81         %if %length(&out_dir) = 0 %then %do;
82             %put ERROR: Output directory not provided in SYSPARM.;
83             %put ERROR: Usage: sas -sysin path\to\script.sas -SYSPARM
83       ! "C:\path\to\data|C:\path\to\output";
3                                           The SAS System                  15:33 Monday, May 18, 2026

84             %abort cancel;
85         %end;
86         
87         /* Create csv_dir for CSV output */
88         %let csv_dir = &out_dir.\DAC_CSV;
89         
90         %put NOTE: Input directory = &in_dir;
NOTE: Input directory = E:\output/DAC_SAS
91         %put NOTE: Output directory = &out_dir;
NOTE: Output directory = E:\output
92         %put NOTE: CSV directory = &csv_dir;
NOTE: CSV directory = E:\output\DAC_CSV
93         
94         /* 2) Point a libname to input directory (for *.sas7bdat) */
95         libname inlib "&in_dir";
NOTE: Libref INLIB was successfully assigned as follows: 
      Engine:        V9 
      Physical Name: E:\output\DAC_SAS
96         
97         /* 3) Create output folder if it does not exist */
98         options noxwait noxsync;
99         data _null_;
100            length out $260 parent $260 rc $260;
101            out = "&out_dir";
102        
103            /* Remove trailing backslash if present */
104            if substr(out, length(out), 1) = '\' then
105                out = substr(out, 1, length(out) - 1);
106        
107            if fileexist(out) then
108                put "NOTE: Directory &out_dir already exists.";
109            else do;
110                /* Get parent directory for dcreate */
111                pos = length(out) - index(reverse(out), '\') + 1;
112                if pos > 0 and pos < length(out) then do;
113                    parent = substr(out, 1, pos - 1);
114                    folder = substr(out, pos + 1);
115                    rc = dcreate(folder, parent);
116                end;
117                else do;
118                    rc = dcreate(out, '');
119                end;
120        
121                if rc ne '' then put "NOTE: Created directory &out_dir successfully.";
122                else put "ERROR: Could not create directory &out_dir";
123            end;
124        run;

