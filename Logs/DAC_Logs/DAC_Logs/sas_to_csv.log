149        
150        /* 6) Macro to export all datasets to CSV in csv_dir */
151        %macro export_all_to_csv;
152            %local n i dsname;
153            proc sql noprint;
154                select count(*) into :n trimmed from work._dslist;
155            quit;
156        
157            %if &n = 0 %then %do;
158                %put NOTE: No SAS datasets found in &in_dir;
159                %return;
160            %end;
161        
162            %do i = 1 %to &n;
163                proc sql noprint;
164                    select memname into :dsname trimmed
5                                           The SAS System                  15:33 Monday, May 18, 2026

165                    from work._dslist
166                    where monotonic() = &i;
167                quit;
168                %let csvfile = &csv_dir.\&dsname..csv;
169                %put NOTE: Exporting INLIB.&dsname to &csvfile;
170                proc export data=inlib.&dsname
171                    outfile="&csvfile"
172                    dbms=csv
173                    replace;
174                run;
175            %end;
176        %mend export_all_to_csv;
177        
178        %export_all_to_csv;
