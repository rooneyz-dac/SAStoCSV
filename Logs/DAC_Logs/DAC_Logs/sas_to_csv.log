163        /* 6) Macro to export all datasets to CSV in csv_dir */
164        %macro export_all_to_csv;
165            %local n i dsname;
166            proc sql noprint;
167                select count(*) into :n trimmed from work._dslist;
168            quit;
169        
170            %if &n = 0 %then %do;
171                %put NOTE: No SAS datasets found in &in_dir;
172                %return;
173            %end;
174        
175            %do i = 1 %to &n;
176                proc sql noprint;
177                    select memname into :dsname trimmed
178                    from work._dslist
179                    where monotonic() = &i;
180                quit;
181                %let csvfile = &csv_dir.\&dsname..csv;
182                %put NOTE: Exporting INLIB.&dsname to &csvfile;
183                proc export data=inlib.&dsname
184                    outfile="&csvfile"
185                    dbms=csv
186                    replace;
187                run;
188            %end;
189        %mend export_all_to_csv;
190        
191        %export_all_to_csv;
