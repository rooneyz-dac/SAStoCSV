98         /* 3) Create output folder if it does not exist */
99         options noxwait noxsync;
100        data _null_;
101            length out $260 parent $260 rc $260;
102            out = "&out_dir";
103        
104            /* Remove trailing backslash if present */
105            if substr(out, length(out), 1) = '\' then
106                out = substr(out, 1, length(out) - 1);
107        
108            if fileexist(out) then
109                put "NOTE: Directory &out_dir already exists.";
110            else do;
111                /* Get parent directory for dcreate */
112                pos = length(out) - index(reverse(out), '\') + 1;
113                if pos > 0 and pos < length(out) then do;
114                    parent = substr(out, 1, pos - 1);
115                    folder = substr(out, pos + 1);
116                    rc = dcreate(folder, parent);
117                end;
118                else do;
119                    rc = dcreate(out, '');
120                end;
121        
122                if rc ne '' then put "NOTE: Created directory &out_dir successfully.";
123                else put "ERROR: Could not create directory &out_dir";
124            end;
125        run;

