138        /* 4) Set up error log file in output directory */
139        filename errlog "&out_dir.\error_log.txt";
140        
141        /* 5) Get list of all datasets in INDIR */
142        proc sql noprint;
143            create table work._dslist as
144            select memname
145            from dictionary.tables
146            where libname = upcase('INLIB')
147            order by memname;
NOTE: Table WORK._DSLIST created, with 37 rows and 1 columns.

148        quit;
NOTE: PROCEDURE SQL used (Total process time):
