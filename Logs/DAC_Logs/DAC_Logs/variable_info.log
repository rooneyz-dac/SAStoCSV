195            /**Set output file path**/
196            /**When name_dir is provided (XPT-to-SAS conversion scenario), use it for   **/
197            /**deriving the path segments in the output filename so the name reflects    **/
198            /**the original study directory rather than the DAC_SDTM conversion folder. **/
199            /**Use both \ and / as path delimiters to handle Windows and Unix paths.    **/
200            %local out_file g_parent gg_parent ggg_parent name_path;
201            %if %length(%superq(name_dir)) > 0 %then %let name_path = &name_dir;
202            %else %let name_path = &indir;
203            %let g_parent = %scan(&name_path, -1, \/);
204            %let gg_parent = %scan(&name_path, -2, \/);
205            %let ggg_parent = %scan(&name_path, -3, \/);
206            %let out_file =
206      ! &doc_dir\variable_info_%sysfunc(compress(&ggg_parent,,ka))_%sysfunc(compress(&gg_parent,,ka
206      ! ))_%sysfunc(compress(&g_parent,,ka))_%sysfunc(today(),yymmddn8.).xlsx;
207            %put DEBUG: Output file = &out_file;
208        
209            /**Get variable information**/
210            ods output variables=allvarout;
211        
212            proc contents data=INLIB._all_ memtype=data;
213            run;
214        
215            /**Sort data by dataset and variable number**/
216            proc sort data=allvarout;
217                by member num;
218            run;
219        
220            /**Rename variant column names to standard desired names**/
221            /**If a variant column name is found AND the target standard name does    **/
222            /**not already exist, the column is renamed to the standard name.        **/
223            %local rename_pairs renamed_log;
224            %let rename_pairs = ;
225            %let renamed_log = ;
226        
227            data _col_map_;
228                length variant $32 standard $32;
229                /* NUM variants (underscore-separated) */
230                variant='VARIABLE_NUMBER'; standard='NUM'; output;
231                variant='VAR_NUM';         standard='NUM'; output;
232                variant='VAR_NO';          standard='NUM'; output;
233                variant='NUMBER';          standard='NUM'; output;
234                variant='NO';              standard='NUM'; output;
235                /* NUM variants (space-separated — VALIDVARNAME=ANY) */
236                variant='VARIABLE NUMBER'; standard='NUM'; output;
237                variant='VAR NUM';         standard='NUM'; output;
238                variant='VAR NO';          standard='NUM'; output;
239                /* VARIABLE variants (underscore-separated) */
240                variant='VARIABLE_NAME';   standard='VARIABLE'; output;
241                variant='VAR_NAME';        standard='VARIABLE'; output;
242                variant='NAME';            standard='VARIABLE'; output;
243                /* VARIABLE variants (space-separated — VALIDVARNAME=ANY) */
244                variant='VARIABLE NAME';   standard='VARIABLE'; output;
245                variant='VAR NAME';        standard='VARIABLE'; output;
246                /* TYPE variants (underscore-separated) */
6                                           The SAS System                  15:33 Monday, May 18, 2026

247                variant='VAR_TYPE';        standard='TYPE'; output;
248                variant='DATA_TYPE';       standard='TYPE'; output;
249                variant='VARIABLE_TYPE';   standard='TYPE'; output;
250                /* TYPE variants (space-separated — VALIDVARNAME=ANY) */
251                variant='VAR TYPE';        standard='TYPE'; output;
252                variant='DATA TYPE';       standard='TYPE'; output;
253                variant='VARIABLE TYPE';   standard='TYPE'; output;
254                /* LEN variants */
255                variant='LENGTH';          standard='LEN'; output;
256                variant='SIZE';            standard='LEN'; output;
257                /* POS variants (underscore-separated) */
258                variant='POSITION';        standard='POS'; output;
259                variant='START_POSITION';  standard='POS'; output;
260                variant='COLUMN_POSITION'; standard='POS'; output;
261                variant='START';           standard='POS'; output;
262                /* POS variants (space-separated — VALIDVARNAME=ANY) */
263                variant='START POSITION';  standard='POS'; output;
264                variant='COLUMN POSITION'; standard='POS'; output;
265                /* LABEL variants (underscore-separated) */
266                variant='VARIABLE_LABEL';  standard='LABEL'; output;
267                variant='VAR_LABEL';       standard='LABEL'; output;
268                variant='DESCRIPTION';     standard='LABEL'; output;
269                variant='DESC';            standard='LABEL'; output;
270                /* LABEL variants (space-separated — VALIDVARNAME=ANY) */
271                variant='VARIABLE LABEL';  standard='LABEL'; output;
272                variant='VAR LABEL';       standard='LABEL'; output;
273            run;
274        
275            proc sql noprint;
276                /* Build rename pairs: only rename if variant exists and target does not.
277                   Use the actual column name from dictionary.columns (b.name) for the
278                   left side of the rename pair.  Wrap names containing spaces in SAS
279                   name literals ('name'n) so PROC DATASETS RENAME works correctly
280                   under VALIDVARNAME=ANY. */
281                select case
282                           when indexc(strip(b.name), ' ') > 0
283                           then cats("'", strip(b.name), "'n=", a.standard)
284                           else cats(strip(b.name), '=', a.standard)
285                       end
286                    into :rename_pairs separated by ' '
287                from _col_map_ a
288                inner join dictionary.columns b
289                    on upcase(b.name) = upcase(a.variant)
290                    and b.libname = 'WORK' and b.memname = 'ALLVAROUT'
291                where upcase(a.standard) not in (
292                    select upcase(name) from dictionary.columns
293                    where libname = 'WORK' and memname = 'ALLVAROUT'
294                );
295        
296                /* Build human-readable log of renames */
297                select catx(' -> ', strip(b.name), a.standard)
298                    into :renamed_log separated by ', '
299                from _col_map_ a
300                inner join dictionary.columns b
7                                           The SAS System                  15:33 Monday, May 18, 2026

301                    on upcase(b.name) = upcase(a.variant)
302                    and b.libname = 'WORK' and b.memname = 'ALLVAROUT'
303                where upcase(a.standard) not in (
304                    select upcase(name) from dictionary.columns
305                    where libname = 'WORK' and memname = 'ALLVAROUT'
306                );
307            quit;
308        
309            %if %length(&rename_pairs) > 0 %then %do;
310                proc datasets library=work nolist nodetails;
311                    modify allvarout;
312                    rename &rename_pairs;
313                quit;
314                %put DEBUG: Renamed variant columns to standard names: &renamed_log;
315                %put NOTE: ************************************************************;
316                %put NOTE: *** Columns renamed to standard names: &renamed_log ***;
317                %put NOTE: ************************************************************;
318            %end;
319            %else %do;
320                %put DEBUG: No variant column names found - all columns already use standard names;
321            %end;
322        
323            proc datasets library=work nolist nodetails;
324                delete _col_map_;
325            quit;
326        
327            /**Identify and drop columns not in the desired list**/
328            /**Desired output columns: NUM, VARIABLE, TYPE, LEN, POS, LABEL       **/
329            /**MEMBER is retained for BY-group processing but excluded from output.**/
330            %local drop_cols;
331            proc contents data=allvarout out=_colinfo_(keep=name) noprint;
332            run;
333        
334            proc sql noprint;
335                select upcase(name) into :drop_cols separated by ' '
336                from _colinfo_
337                where upcase(name) not in ('NUM', 'VARIABLE', 'TYPE', 'LEN', 'POS', 'LABEL',
337      ! 'MEMBER');
338            quit;
339        
340            %let drop_cols = %sysfunc(strip(&drop_cols));
341        
342            %if %length(&drop_cols) > 0 %then %do;
343                %put DEBUG: Dropping columns not in desired list: &drop_cols;
344                %put NOTE: ************************************************************;
345                %put NOTE: *** Columns dropped from output: &drop_cols ***;
346                %put NOTE: ************************************************************;
347                data allvarout;
348                    set allvarout(drop=&drop_cols);
349                run;
350            %end;
351            %else %do;
352                %put DEBUG: No columns to drop - all columns are in the desired list;
353            %end;
