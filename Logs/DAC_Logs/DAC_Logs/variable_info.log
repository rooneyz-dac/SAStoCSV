359            /**Create Excel output file with separate sheets per dataset**/
360            /**Output columns: NUM, VARIABLE, TYPE, LEN, POS, LABEL              **/
361            options nobyline;
362            ods excel file="&out_file"
363                options(sheet_name="#BYVAL(member)" embedded_titles='yes');
364        
365            proc report data=allvarout nowindows headline;
366                columns num variable type len pos label;
367                define num      / display 'Num'
368                                  style(header)=[just=center]
369                                  style(column)=[cellwidth=0.9in just=center];
370                define variable / display 'Variable'
371                                  style(header)=[just=center]
372                                  style(column)=[cellwidth=1.5in just=center];
373                define type     / display 'Type'
374                                  style(header)=[just=center]
375                                  style(column)=[cellwidth=0.75in just=center];
376                define len      / display 'Len'
377                                  style(header)=[just=center]
378                                  style(column)=[cellwidth=0.75in just=center];
379                define pos      / display 'Pos'
380                                  style(header)=[just=center]
381                                  style(column)=[cellwidth=0.9in just=center];
382                define label    / display 'Label'
383                                  style(header)=[just=center]
384                                  style(column)=[cellwidth=3in just=center];
385                by member;
386                title "Variables in #BYVAL(member) Dataset";
387            run;
388        
389            title;
390        
391            ods excel close;
392        
393            /**Clean up**/
394            proc datasets library=work nolist nodetails;
395                delete allvarout;
396            quit;
397        
398            libname INLIB clear;
399        
