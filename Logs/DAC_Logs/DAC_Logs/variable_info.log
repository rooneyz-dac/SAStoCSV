103        %macro variable_info_cli;
104            /**Force V7 variable naming so PROC CONTENTS ODS output uses standard**/
105            /**column names (Num, Variable, Type, Len, Pos, Label) instead of the **/
106            /**space-containing names produced under VALIDVARNAME=ANY             **/
107            /**(e.g. 'Variable Number' instead of 'Num').                        **/
108            options validvarname=v7;
109        
110            /**Parse SYSPARM for input and output paths**/
111            /**Optional third segment: pipe-delimited key=value pairs (e.g. name_dir=...) **/
112            %local sysparm_value indir outdir pipe_pos name_dir;
113            %let sysparm_value = &sysparm;
114            %let name_dir = ;
115            %put DEBUG: Raw SYSPARM value = &sysparm_value;
116        
117            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
118            %put DEBUG: Pipe position = &pipe_pos;
119        
120            %if &pipe_pos > 0 %then %do;
121                %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
122                %local remaining pipe2_pos;
123                %let remaining = %substr(&sysparm_value, %eval(&pipe_pos + 1));
124        
125                /* Check for additional pipe-separated optional key=value parameters */
126                %let pipe2_pos = %sysfunc(findc(&remaining, |));
127                %if &pipe2_pos > 0 %then %do;
128                    %let outdir = %substr(&remaining, 1, %eval(&pipe2_pos - 1));
129                    %local extra_params ep_count ep_i ep_curr ep_name eq_pos ep_value;
130                    %let extra_params = %substr(&remaining, %eval(&pipe2_pos + 1));
131                    %let ep_count = %sysfunc(countw(&extra_params, |));
132                    %do ep_i = 1 %to &ep_count;
133                        %let ep_curr = %scan(&extra_params, &ep_i, |);
134                        %let eq_pos = %sysfunc(findc(&ep_curr, =));
135                        %if &eq_pos > 0 %then %do;
136                            %let ep_name = %qupcase(%substr(&ep_curr, 1, %eval(&eq_pos - 1)));
137                            %if &eq_pos < %length(&ep_curr) %then %do;
138                                %let ep_value = %substr(&ep_curr, %eval(&eq_pos + 1));
139                            %end;
140                            %else %do;
4                                           The SAS System               11:44 Wednesday, May 20, 2026

141                                %let ep_value = ;
142                            %end;
143                            %if &ep_name = NAME_DIR %then %do;
144                                %let name_dir = &ep_value;
145                            %end;
146                        %end;
147                    %end;
148                %end;
149                %else %do;
150                    %let outdir = &remaining;
151                %end;
152            %end;
153            %else %do;
154                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
155                %abort;
156            %end;
157        
158            %put DEBUG: Input Directory = &indir;
159            %put DEBUG: Output Directory = &outdir;
160        
161            /**Validate directories exist**/
162            %local indir_exist outdir_exist;
163            %let indir_exist = %sysfunc(fileexist(&indir));
164            %let outdir_exist = %sysfunc(fileexist(&outdir));
165        
166            %put DEBUG: Input directory exists = &indir_exist;
167            %put DEBUG: Output directory exists = &outdir_exist;
168        
169            %if &indir_exist = 0 %then %do;
170                %put ERROR: Input directory does not exist: &indir;
171                %abort;
172            %end;
173        
174            %if &outdir_exist = 0 %then %do;
175                %put ERROR: Output directory does not exist: &outdir;
176                %abort;
177            %end;
178        
179            /**Create DAC_Documents folder if it doesn't exist**/
180            %local doc_dir doc_exist rc;
181            %let doc_dir = &outdir\DAC_Documents;
182            %let doc_exist = %sysfunc(fileexist(&doc_dir));
183        
184            %if &doc_exist = 0 %then %do;
185                %put DEBUG: Creating directory &doc_dir;
186                %let rc = %sysfunc(dcreate(DAC_Documents, &outdir));
187                %if %length(&rc) = 0 %then %do;
188                    %put ERROR: Failed to create directory &doc_dir;
189                    %abort;
190                %end;
191                %put DEBUG: Successfully created &doc_dir;
192            %end;
193            %else %do;
194                %put DEBUG: Directory &doc_dir already exists;
5                                           The SAS System               11:44 Wednesday, May 20, 2026

195            %end;
196        
197            /**Assign library to input directory**/
198            libname INLIB "&indir";
199        
200            %if %sysfunc(libref(INLIB)) ^= 0 %then %do;
201                %put ERROR: Failed to assign library to &indir;
202                %abort;
203            %end;
204        
205            /**Set output file path**/
206            /**When name_dir is provided (XPT-to-SAS conversion scenario), use it for   **/
207            /**deriving the path segments in the output filename so the name reflects    **/
208            /**the original study directory rather than the DAC_SDTM conversion folder. **/
209            /**Use both \ and / as path delimiters to handle Windows and Unix paths.    **/
210            %local out_file g_parent gg_parent ggg_parent name_path;
211            %if %length(%superq(name_dir)) > 0 %then %let name_path = &name_dir;
212            %else %let name_path = &indir;
213            %let g_parent = %scan(&name_path, -1, \/);
214            %let gg_parent = %scan(&name_path, -2, \/);
215            %let ggg_parent = %scan(&name_path, -3, \/);
216            %let out_file =
216      ! &doc_dir\variable_info_%sysfunc(compress(&ggg_parent,'_',ka))_%sysfunc(compress(&gg_parent,
216      ! '_',ka))_%sysfunc(compress(&g_parent,'_',ka))_%sysfunc(today(),yymmddn8.).xlsx;
217            %put DEBUG: Output file = &out_file;
218        
219            /**Get variable information**/
220            ods output variables=allvarout;
221        
222            proc contents data=INLIB._all_ memtype=data;
223            run;
224        
225            /**Sort data by dataset and variable number**/
226            proc sort data=allvarout;
227                by member num;
228            run;
229        
230            /**Rename variant column names to standard desired names**/
231            /**If a variant column name is found AND the target standard name does    **/
232            /**not already exist, the column is renamed to the standard name.        **/
233            %local rename_pairs renamed_log;
234            %let rename_pairs = ;
235            %let renamed_log = ;
236        
237            data _col_map_;
238                length variant $32 standard $32;
239                /* NUM variants (underscore-separated) */
240                variant='VARIABLE_NUMBER'; standard='NUM'; output;
241                variant='VAR_NUM';         standard='NUM'; output;
242                variant='VAR_NO';          standard='NUM'; output;
243                variant='NUMBER';          standard='NUM'; output;
244                variant='NO';              standard='NUM'; output;
245                /* NUM variants (space-separated — VALIDVARNAME=ANY) */
246                variant='VARIABLE NUMBER'; standard='NUM'; output;
6                                           The SAS System               11:44 Wednesday, May 20, 2026

247                variant='VAR NUM';         standard='NUM'; output;
248                variant='VAR NO';          standard='NUM'; output;
249                /* VARIABLE variants (underscore-separated) */
250                variant='VARIABLE_NAME';   standard='VARIABLE'; output;
251                variant='VAR_NAME';        standard='VARIABLE'; output;
252                variant='NAME';            standard='VARIABLE'; output;
253                /* VARIABLE variants (space-separated — VALIDVARNAME=ANY) */
254                variant='VARIABLE NAME';   standard='VARIABLE'; output;
255                variant='VAR NAME';        standard='VARIABLE'; output;
256                /* TYPE variants (underscore-separated) */
257                variant='VAR_TYPE';        standard='TYPE'; output;
258                variant='DATA_TYPE';       standard='TYPE'; output;
259                variant='VARIABLE_TYPE';   standard='TYPE'; output;
260                /* TYPE variants (space-separated — VALIDVARNAME=ANY) */
261                variant='VAR TYPE';        standard='TYPE'; output;
262                variant='DATA TYPE';       standard='TYPE'; output;
263                variant='VARIABLE TYPE';   standard='TYPE'; output;
264                /* LEN variants */
265                variant='LENGTH';          standard='LEN'; output;
266                variant='SIZE';            standard='LEN'; output;
267                /* POS variants (underscore-separated) */
268                variant='POSITION';        standard='POS'; output;
269                variant='START_POSITION';  standard='POS'; output;
270                variant='COLUMN_POSITION'; standard='POS'; output;
271                variant='START';           standard='POS'; output;
272                /* POS variants (space-separated — VALIDVARNAME=ANY) */
273                variant='START POSITION';  standard='POS'; output;
274                variant='COLUMN POSITION'; standard='POS'; output;
275                /* LABEL variants (underscore-separated) */
276                variant='VARIABLE_LABEL';  standard='LABEL'; output;
277                variant='VAR_LABEL';       standard='LABEL'; output;
278                variant='DESCRIPTION';     standard='LABEL'; output;
279                variant='DESC';            standard='LABEL'; output;
280                /* LABEL variants (space-separated — VALIDVARNAME=ANY) */
281                variant='VARIABLE LABEL';  standard='LABEL'; output;
282                variant='VAR LABEL';       standard='LABEL'; output;
283            run;
284        
285            proc sql noprint;
286                /* Build rename pairs: only rename if variant exists and target does not.
287                   Use the actual column name from dictionary.columns (b.name) for the
288                   left side of the rename pair.  Wrap names containing spaces in SAS
289                   name literals ('name'n) so PROC DATASETS RENAME works correctly
290                   under VALIDVARNAME=ANY. */
291                select case
292                           when indexc(strip(b.name), ' ') > 0
293                           then cats("'", strip(b.name), "'n=", a.standard)
294                           else cats(strip(b.name), '=', a.standard)
295                       end
296                    into :rename_pairs separated by ' '
297                from _col_map_ a
298                inner join dictionary.columns b
299                    on upcase(b.name) = upcase(a.variant)
300                    and b.libname = 'WORK' and b.memname = 'ALLVAROUT'
7                                           The SAS System               11:44 Wednesday, May 20, 2026

301                where upcase(a.standard) not in (
302                    select upcase(name) from dictionary.columns
303                    where libname = 'WORK' and memname = 'ALLVAROUT'
304                );
305        
306                /* Build human-readable log of renames */
307                select catx(' -> ', strip(b.name), a.standard)
308                    into :renamed_log separated by ', '
309                from _col_map_ a
310                inner join dictionary.columns b
311                    on upcase(b.name) = upcase(a.variant)
312                    and b.libname = 'WORK' and b.memname = 'ALLVAROUT'
313                where upcase(a.standard) not in (
314                    select upcase(name) from dictionary.columns
315                    where libname = 'WORK' and memname = 'ALLVAROUT'
316                );
317            quit;
318        
319            %if %length(&rename_pairs) > 0 %then %do;
320                proc datasets library=work nolist nodetails;
321                    modify allvarout;
322                    rename &rename_pairs;
323                quit;
324                %put DEBUG: Renamed variant columns to standard names: &renamed_log;
325                %put NOTE: ************************************************************;
326                %put NOTE: *** Columns renamed to standard names: &renamed_log ***;
327                %put NOTE: ************************************************************;
328            %end;
329            %else %do;
330                %put DEBUG: No variant column names found - all columns already use standard names;
331            %end;
332        
333            proc datasets library=work nolist nodetails;
334                delete _col_map_;
335            quit;
336        
337            /**Identify and drop columns not in the desired list**/
338            /**Desired output columns: NUM, VARIABLE, TYPE, LEN, POS, LABEL       **/
339            /**MEMBER is retained for BY-group processing but excluded from output.**/
340            %local drop_cols;
341            proc contents data=allvarout out=_colinfo_(keep=name) noprint;
342            run;
343        
344            proc sql noprint;
345                select upcase(name) into :drop_cols separated by ' '
346                from _colinfo_
347                where upcase(name) not in ('NUM', 'VARIABLE', 'TYPE', 'LEN', 'POS', 'LABEL',
347      ! 'MEMBER');
348            quit;
349        
350            %if %length(&drop_cols) > 0 %then
351                %let drop_cols = %sysfunc(strip(&drop_cols));
352        
353            %if %length(&drop_cols) > 0 %then %do;
8                                           The SAS System               11:44 Wednesday, May 20, 2026

354                %put DEBUG: Dropping columns not in desired list: &drop_cols;
355                %put NOTE: ************************************************************;
356                %put NOTE: *** Columns dropped from output: &drop_cols ***;
357                %put NOTE: ************************************************************;
358                data allvarout;
359                    set allvarout(drop=&drop_cols);
360                run;
361            %end;
362            %else %do;
363                %put DEBUG: No columns to drop - all columns are in the desired list;
364            %end;
365        
366            proc datasets library=work nolist nodetails;
367                delete _colinfo_;
368            quit;
369        
370            /**Create Excel output file with separate sheets per dataset**/
371            /**Output columns: NUM, VARIABLE, TYPE, LEN, POS, LABEL              **/
372            options nobyline;
373            ods excel file="&out_file"
374                options(sheet_name="#BYVAL(member)" embedded_titles='yes');
375        
376            proc report data=allvarout nowindows headline;
377                columns num variable type len pos label;
378                define num      / display 'Num'
379                                  style(header)=[just=center]
380                                  style(column)=[cellwidth=0.9in just=center];
381                define variable / display 'Variable'
382                                  style(header)=[just=center]
383                                  style(column)=[cellwidth=1.5in just=center];
384                define type     / display 'Type'
385                                  style(header)=[just=center]
386                                  style(column)=[cellwidth=0.75in just=center];
387                define len      / display 'Len'
388                                  style(header)=[just=center]
389                                  style(column)=[cellwidth=0.75in just=center];
390                define pos      / display 'Pos'
391                                  style(header)=[just=center]
392                                  style(column)=[cellwidth=0.9in just=center];
393                define label    / display 'Label'
394                                  style(header)=[just=center]
395                                  style(column)=[cellwidth=3in just=center];
396                by member;
397                title "Variables in #BYVAL(member) Dataset";
398            run;
399        
400            title;
401        
402            ods excel close;
403        
404            /**Clean up**/
405            proc datasets library=work nolist nodetails;
406                delete allvarout;
407            quit;
