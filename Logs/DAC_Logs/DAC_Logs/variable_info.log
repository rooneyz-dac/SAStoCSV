93         %macro variable_info_cli;
94             /**Force V7 variable naming so PROC CONTENTS ODS output uses standard**/
95             /**column names (Num, Variable, Type, Len, Pos, Label) instead of the **/
96             /**space-containing names produced under VALIDVARNAME=ANY             **/
97             /**(e.g. 'Variable Number' instead of 'Num').                        **/
98             options validvarname=v7;
99         
100            /**Parse SYSPARM for input and output paths**/
101            /**Optional third segment: pipe-delimited key=value pairs (e.g. name_dir=...) **/
102            %local sysparm_value indir outdir pipe_pos name_dir;
103            %let sysparm_value = &sysparm;
104            %let name_dir = ;
105            %put DEBUG: Raw SYSPARM value = &sysparm_value;
106        
107            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
108            %put DEBUG: Pipe position = &pipe_pos;
109        
110            %if &pipe_pos > 0 %then %do;
111                %let indir = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
112                %local remaining pipe2_pos;
113                %let remaining = %substr(&sysparm_value, %eval(&pipe_pos + 1));
114        
115                /* Check for additional pipe-separated optional key=value parameters */
116                %let pipe2_pos = %sysfunc(findc(&remaining, |));
117                %if &pipe2_pos > 0 %then %do;
118                    %let outdir = %substr(&remaining, 1, %eval(&pipe2_pos - 1));
119                    %local extra_params ep_count ep_i ep_curr ep_name eq_pos ep_value;
120                    %let extra_params = %substr(&remaining, %eval(&pipe2_pos + 1));
121                    %let ep_count = %sysfunc(countw(&extra_params, |));
122                    %do ep_i = 1 %to &ep_count;
123                        %let ep_curr = %scan(&extra_params, &ep_i, |);
124                        %let eq_pos = %sysfunc(findc(&ep_curr, =));
125                        %if &eq_pos > 0 %then %do;
126                            %let ep_name = %qupcase(%substr(&ep_curr, 1, %eval(&eq_pos - 1)));
127                            %if &eq_pos < %length(&ep_curr) %then %do;
128                                %let ep_value = %substr(&ep_curr, %eval(&eq_pos + 1));
129                            %end;
130                            %else %do;
131                                %let ep_value = ;
132                            %end;
133                            %if &ep_name = NAME_DIR %then %do;
134                                %let name_dir = &ep_value;
135                            %end;
136                        %end;
137                    %end;
138                %end;
139                %else %do;
140                    %let outdir = &remaining;
4                                           The SAS System                  15:33 Monday, May 18, 2026

141                %end;
142            %end;
143            %else %do;
144                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
145                %abort;
146            %end;
147        
148            %put DEBUG: Input Directory = &indir;
149            %put DEBUG: Output Directory = &outdir;
150        
151            /**Validate directories exist**/
152            %local indir_exist outdir_exist;
153            %let indir_exist = %sysfunc(fileexist(&indir));
154            %let outdir_exist = %sysfunc(fileexist(&outdir));
155        
156            %put DEBUG: Input directory exists = &indir_exist;
157            %put DEBUG: Output directory exists = &outdir_exist;
158        
159            %if &indir_exist = 0 %then %do;
160                %put ERROR: Input directory does not exist: &indir;
161                %abort;
162            %end;
163        
164            %if &outdir_exist = 0 %then %do;
165                %put ERROR: Output directory does not exist: &outdir;
166                %abort;
167            %end;
168        
169            /**Create DAC_Documents folder if it doesn't exist**/
170            %local doc_dir doc_exist rc;
171            %let doc_dir = &outdir\DAC_Documents;
172            %let doc_exist = %sysfunc(fileexist(&doc_dir));
173        
174            %if &doc_exist = 0 %then %do;
175                %put DEBUG: Creating directory &doc_dir;
176                %let rc = %sysfunc(dcreate(DAC_Documents, &outdir));
177                %if &rc = %then %do;
178                    %put ERROR: Failed to create directory &doc_dir;
179                    %abort;
180                %end;
181                %put DEBUG: Successfully created &doc_dir;
182            %end;
183            %else %do;
184                %put DEBUG: Directory &doc_dir already exists;
185            %end;
