173        /* ================================================================
174           Main macro
175        ================================================================ */
176        %macro rename_study_domains;
177        
178            %let sysparm_value = &sysparm;
179            %put NOTE: [rename_study_domains] Raw SYSPARM = &sysparm_value;
180        
181            /* ---- Parse SYSPARM: input_dir|output_dir ---- */
182            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
183            %if &pipe_pos > 0 %then %do;
184                %let indir  = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
185                %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
186            %end;
187            %else %do;
188                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
189                %abort;
190            %end;
191        
192            %put NOTE: [rename_study_domains] Input Directory  = &indir;
193            %put NOTE: [rename_study_domains] Output Directory = &outdir;
194        
5                                           The SAS System               11:43 Wednesday, May 20, 2026

195            /* ---- Derive output folder name from the input directory leaf segment ---- */
196            /* Handles both Windows backslash and Unix forward slash separators.         */
197            %let parent_folder_name = %scan(&indir, -1, \/);
198            %let dac_sas_folder     = DAC_&parent_folder_name;
199            %put NOTE: [rename_study_domains] SAS output folder name = &dac_sas_folder;
200        
201            /* ---- Validate directories ---- */
202            %if %sysfunc(fileexist(&indir))  = 0 %then %do;
203                %put ERROR: Input directory does not exist: &indir;
204                %abort;
205            %end;
206            %if %sysfunc(fileexist(&outdir)) = 0 %then %do;
207                %put ERROR: Output directory does not exist: &outdir;
208                %abort;
209            %end;
210        
211        
212            /* ============================================================
213               PART 1: Process SAS7BDAT files
214               Uses dictionary.tables to discover library members, then
215               renames with proc datasets change (logic from
216               rename_study_domains_ZRlocalCopy.sas).
217               ============================================================ */
218        
219            /* Point a libname at the input directory so SAS can query its
220               member metadata via dictionary.tables */
221            libname _inlib "&indir";
222        
223            /* Build a table of datasets that need renaming (have a suffix).
224               Standard name = last token after the final underscore, e.g.
225               BERKELEY_AE -> AE, BERKELEY_SUPPAE -> SUPPAE. */
226            proc sql noprint;
227                create table _work_sas as
228                select
229                    memname,
230                    scan(memname, -1, '_') as standard_name length=32
231                from dictionary.tables
232                where upcase(libname) = '_INLIB'
233                  and index(memname, '_') > 0;
234        
235                select count(*) into :sas_rename_count trimmed from _work_sas;
236        
237                select count(*) into :sas_total trimmed
238                from dictionary.tables
239                where upcase(libname) = '_INLIB';
240            quit;
241        
242            %put NOTE: Found &sas_total SAS7BDAT dataset(s) in library, &sas_rename_count require
242      ! renaming.;
243        
244            %if &sas_rename_count > 0 %then %do;
245        
246                /* Check for duplicate standard names and warn/exclude */
247                proc sql noprint;
6                                           The SAS System               11:43 Wednesday, May 20, 2026

248                    create table _work_sas_dups as
249                    select standard_name, count(*) as n
250                    from _work_sas
251                    group by standard_name
252                    having count(*) > 1;
253                    select count(*) into :sas_dup_count trimmed from _work_sas_dups;
254                quit;
255        
256                %if &sas_dup_count > 0 %then %do;
257                    %put WARNING: Multiple SAS datasets map to the same standard name.;
258                    %put WARNING: The following datasets will be SKIPPED to avoid overwriting:;
259                    data _null_;
260                        set _work_sas_dups;
261                        put "  Standard name '" standard_name +(-1)
262                            "' has " n "conflicting source datasets.";
263                    run;
264                    /* Exclude datasets with duplicate standard names */
265                    proc sql noprint;
266                        delete from _work_sas
267                        where standard_name in (select standard_name from _work_sas_dups);
268                    quit;
269                    /* Re-count after exclusion */
270                    proc sql noprint;
271                        select count(*) into :sas_rename_count trimmed from _work_sas;
272                    quit;
273                %end;
274        
275                proc datasets lib=work nolist; delete _work_sas_dups; quit;
276        
277                %if &sas_rename_count > 0 %then %do;
278        
279                    /* Create DAC_<ParentFolderName> output directory if needed */
280                    %let dac_sas_dir   = &outdir\&dac_sas_folder;
281                    %let dac_sas_exist = %sysfunc(fileexist(&dac_sas_dir));
282        
283                    %if &dac_sas_exist = 0 %then %do;
284                        %put NOTE: Creating directory &dac_sas_dir;
285                        %let _rc = %sysfunc(dcreate(&dac_sas_folder, &outdir));
286                        %if %length(&_rc) = 0 %then %do;
287                            %put ERROR: Failed to create directory &dac_sas_dir;
288                            libname _inlib clear;
289                            %abort;
290                        %end;
291                    %end;
292                    %else %do;
293                        %put NOTE: Directory &dac_sas_dir already exists.;
294                    %end;
295        
296                    /* Copy ALL datasets from input library to &dac_sas_folder so the
297                       output folder is a complete, self-consistent set.
298                       Original input files are never modified. */
299                    libname _outdac "&dac_sas_dir";
300                    proc copy in=_inlib out=_outdac memtype=data; run;
301                    libname _inlib clear;
7                                           The SAS System               11:43 Wednesday, May 20, 2026

302        
303                    /* Rename datasets that have suffixes in &dac_sas_folder using
304                       proc datasets change (same approach as the original script) */
305                    data _null_;
306                        set _work_sas;
307                        cmd = 'proc datasets lib=_outdac nolist; change ' ||
308                              strip(memname) || ' = ' || strip(standard_name) || '; quit;';
309                        call execute(cmd);
310                        put cmd;
311                    run;
312        
313                    libname _outdac clear;
314        
315                    %put NOTE: SAS dataset standardization complete.;
316                    %put NOTE: Standardized SAS files are in: &dac_sas_dir;
317        
318                %end; /* sas_rename_count > 0 after dedup */
319        
320            %end; /* sas_rename_count > 0 */
321            %else %do;
322                %put NOTE: All &sas_total SAS7BDAT dataset(s) already have standard names. No
322      ! &dac_sas_folder folder created.;
323                libname _inlib clear;
324            %end;
325        
326            proc datasets lib=work nolist; delete _work_sas; quit;
327        
328        
329            /* ============================================================
330               PART 2: Process XPT files
331               ============================================================ */
332        
333            filename _xptlst pipe "dir /b ""&indir\*.xpt"" 2>nul";
334        
335            data _work_xpt;
336                infile _xptlst truncover;
337                input filename $256.;
338                if filename = '' then delete;
339                length dsname $32 standard_name $32
340                       xpt_in_path $512 xpt_out_path $512;
341                dsname        = upcase(scan(filename, 1, '.'));
342                standard_name = upcase(scan(dsname,  -1, '_'));
343                needs_rename  = (dsname ne standard_name);
344                xpt_in_path   = "&indir\" || strip(filename);
345                xpt_out_path  = "&outdir\DAC_XPT\" ||
346                                strip(lowcase(standard_name)) || '.xpt';
347            run;
348        
349            filename _xptlst clear;
350        
351            proc sql noprint;
352                select count(*) into :xpt_total        trimmed from _work_xpt;
353                select count(*) into :xpt_rename_count trimmed from _work_xpt
354                    where needs_rename = 1;
8                                           The SAS System               11:43 Wednesday, May 20, 2026

355            quit;
356        
357            %put NOTE: Found &xpt_total XPT file(s), &xpt_rename_count require renaming.;
358        
359            %if &xpt_total > 0 and &xpt_rename_count > 0 %then %do;
360        
361                /* Check for duplicate standard names and warn/exclude */
362                proc sql noprint;
363                    create table _work_xpt_dups as
364                    select standard_name, count(*) as n
365                    from _work_xpt
366                    group by standard_name
367                    having count(*) > 1;
368                    select count(*) into :xpt_dup_count trimmed from _work_xpt_dups;
369                quit;
370        
371                %if &xpt_dup_count > 0 %then %do;
372                    %put WARNING: Multiple XPT datasets map to the same standard name.;
373                    %put WARNING: The following XPT datasets will be SKIPPED:;
374                    data _null_;
375                        set _work_xpt_dups;
376                        put "  Standard name '" standard_name +(-1)
377                            "' has " n "conflicting source datasets.";
378                    run;
379                    proc sql noprint;
380                        delete from _work_xpt
381                        where standard_name in (select standard_name from _work_xpt_dups);
382                    quit;
383                    proc sql noprint;
384                        select count(*) into :xpt_total        trimmed from _work_xpt;
385                        select count(*) into :xpt_rename_count trimmed from _work_xpt
386                            where needs_rename = 1;
387                    quit;
388                %end;
389        
390                proc datasets lib=work nolist; delete _work_xpt_dups; quit;
391        
392                %if &xpt_rename_count > 0 %then %do;
393        
394                    /* Create DAC_XPT output directory if needed */
395                    %let dac_xpt_dir   = &outdir\DAC_XPT;
396                    %let dac_xpt_exist = %sysfunc(fileexist(&dac_xpt_dir));
397        
398                    %if &dac_xpt_exist = 0 %then %do;
399                        %put NOTE: Creating directory &dac_xpt_dir;
400                        %let _rc = %sysfunc(dcreate(DAC_XPT, &outdir));
401                        %if %length(&_rc) = 0 %then %do;
402                            %put ERROR: Failed to create directory &dac_xpt_dir;
403                            %abort;
404                        %end;
405                    %end;
406                    %else %do;
407                        %put NOTE: Directory &dac_xpt_dir already exists.;
408                    %end;
9                                           The SAS System               11:43 Wednesday, May 20, 2026

409        
410                    /* Generate a call to %_copy_xpt_file for each XPT file.
411                       Using %nrstr prevents premature macro resolution of the
412                       parameter values inside the DATA step. */
413                    data _null_;
414                        set _work_xpt;
415                        call execute(
416                            '%_copy_xpt_file(inpath=' || strip(xpt_in_path)   ||
417                            ', outpath='              || strip(xpt_out_path)  ||
418                            ', standard_name='        || strip(standard_name) || ')'
419                        );
420                    run;
421        
422                    %put NOTE: XPT dataset standardization complete.;
423                    %put NOTE: Standardized XPT files are in: &dac_xpt_dir;
424        
425                %end; /* xpt_rename_count > 0 after dedup */
426        
427            %end; /* xpt_total > 0 and xpt_rename_count > 0 */
428            %else %if &xpt_total > 0 %then %do;
429                %put NOTE: All &xpt_total XPT file(s) already have standard names. No DAC_XPT
429      ! folder created.;
430            %end;
431        
432            proc datasets lib=work nolist; delete _work_xpt; quit;
433        
434            %put NOTE: [rename_study_domains] Processing complete.;
435        
436        %mend rename_study_domains;
437        
438        %rename_study_domains;
