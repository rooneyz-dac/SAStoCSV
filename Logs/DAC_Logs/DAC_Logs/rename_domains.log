162        /* ================================================================
163           Main macro
164        ================================================================ */
165        %macro rename_study_domains;
166        
167            %let sysparm_value = &sysparm;
168            %put NOTE: [rename_study_domains] Raw SYSPARM = &sysparm_value;
169        
170            /* ---- Parse SYSPARM: input_dir|output_dir ---- */
171            %let pipe_pos = %sysfunc(findc(&sysparm_value, |));
172            %if &pipe_pos > 0 %then %do;
173                %let indir  = %substr(&sysparm_value, 1, %eval(&pipe_pos - 1));
174                %let outdir = %substr(&sysparm_value, %eval(&pipe_pos + 1));
175            %end;
176            %else %do;
177                %put ERROR: Invalid SYSPARM format. Expected: input_directory|output_directory;
178                %abort;
179            %end;
180        
181            %put NOTE: [rename_study_domains] Input Directory  = &indir;
182            %put NOTE: [rename_study_domains] Output Directory = &outdir;
183        
184            /* ---- Validate directories ---- */
185            %if %sysfunc(fileexist(&indir))  = 0 %then %do;
186                %put ERROR: Input directory does not exist: &indir;
187                %abort;
188            %end;
189            %if %sysfunc(fileexist(&outdir)) = 0 %then %do;
190                %put ERROR: Output directory does not exist: &outdir;
191                %abort;
192            %end;
193        
194        
5                                           The SAS System                  15:33 Monday, May 18, 2026

195            /* ============================================================
196               PART 1: Process SAS7BDAT files
197               Uses dictionary.tables to discover library members, then
198               renames with proc datasets change (logic from
199               rename_study_domains_ZRlocalCopy.sas).
200               ============================================================ */
201        
202            /* Point a libname at the input directory so SAS can query its
203               member metadata via dictionary.tables */
204            libname _inlib "&indir";
205        
206            /* Build a table of datasets that need renaming (have a suffix).
207               Standard name = last token after the final underscore, e.g.
208               BERKELEY_AE -> AE, BERKELEY_SUPPAE -> SUPPAE. */
209            proc sql noprint;
210                create table _work_sas as
211                select
212                    memname,
213                    scan(memname, -1, '_') as standard_name length=32
214                from dictionary.tables
215                where upcase(libname) = '_INLIB'
216                  and index(memname, '_') > 0;
217        
218                select count(*) into :sas_rename_count trimmed from _work_sas;
219        
220                select count(*) into :sas_total trimmed
221                from dictionary.tables
222                where upcase(libname) = '_INLIB';
223            quit;
224        
225            %put NOTE: Found &sas_total SAS7BDAT dataset(s) in library, &sas_rename_count require
225      ! renaming.;
226        
227            %if &sas_rename_count > 0 %then %do;
228        
229                /* Check for duplicate standard names and warn/exclude */
230                proc sql noprint;
231                    create table _work_sas_dups as
232                    select standard_name, count(*) as n
233                    from _work_sas
234                    group by standard_name
235                    having count(*) > 1;
236                    select count(*) into :sas_dup_count trimmed from _work_sas_dups;
237                quit;
238        
239                %if &sas_dup_count > 0 %then %do;
240                    %put WARNING: Multiple SAS datasets map to the same standard name.;
241                    %put WARNING: The following datasets will be SKIPPED to avoid overwriting:;
242                    data _null_;
243                        set _work_sas_dups;
244                        put "  Standard name '" standard_name +(-1)
245                            "' has " n "conflicting source datasets.";
246                    run;
247                    /* Exclude datasets with duplicate standard names */
6                                           The SAS System                  15:33 Monday, May 18, 2026

248                    proc sql noprint;
249                        delete from _work_sas
250                        where standard_name in (select standard_name from _work_sas_dups);
251                    quit;
252                    /* Re-count after exclusion */
253                    proc sql noprint;
254                        select count(*) into :sas_rename_count trimmed from _work_sas;
255                    quit;
256                %end;
257        
258                proc datasets lib=work nolist; delete _work_sas_dups; quit;
259        
260                %if &sas_rename_count > 0 %then %do;
261        
262                    /* Create DAC_SAS output directory if needed */
263                    %let dac_sas_dir   = &outdir\DAC_SAS;
264                    %let dac_sas_exist = %sysfunc(fileexist(&dac_sas_dir));
265        
266                    %if &dac_sas_exist = 0 %then %do;
267                        %put NOTE: Creating directory &dac_sas_dir;
268                        %let _rc = %sysfunc(dcreate(DAC_SAS, &outdir));
269                        %if &_rc = %then %do;
270                            %put ERROR: Failed to create directory &dac_sas_dir;
271                            libname _inlib clear;
272                            %abort;
273                        %end;
274                    %end;
275                    %else %do;
276                        %put NOTE: Directory &dac_sas_dir already exists.;
277                    %end;
278        
279                    /* Copy ALL datasets from input library to DAC_SAS so the
280                       output folder is a complete, self-consistent set.
281                       Original input files are never modified. */
282                    libname _outdac "&dac_sas_dir";
283                    proc copy in=_inlib out=_outdac memtype=data; run;
284                    libname _inlib clear;
285        
286                    /* Rename datasets that have suffixes in DAC_SAS using
287                       proc datasets change (same approach as the original script) */
288                    data _null_;
289                        set _work_sas;
290                        cmd = 'proc datasets lib=_outdac nolist; change ' ||
291                              strip(memname) || ' = ' || strip(standard_name) || '; quit;';
292                        call execute(cmd);
293                        put cmd;
294                    run;
295        
296                    libname _outdac clear;
297        
298                    %put NOTE: SAS dataset standardization complete.;
299                    %put NOTE: Standardized SAS files are in: &dac_sas_dir;
300        
301                %end; /* sas_rename_count > 0 after dedup */
7                                           The SAS System                  15:33 Monday, May 18, 2026

302        
303            %end; /* sas_rename_count > 0 */
304            %else %do;
305                %put NOTE: All &sas_total SAS7BDAT dataset(s) already have standard names. No
305      ! DAC_SAS folder created.;
306                libname _inlib clear;
307            %end;
308        
309            proc datasets lib=work nolist; delete _work_sas; quit;
310        
311        
312            /* ============================================================
313               PART 2: Process XPT files
314               ============================================================ */
315        
316            filename _xptlst pipe "dir /b ""&indir\*.xpt"" 2>nul";
317        
318            data _work_xpt;
319                infile _xptlst truncover;
320                input filename $256.;
321                if filename = '' then delete;
322                length dsname $32 standard_name $32
323                       xpt_in_path $512 xpt_out_path $512;
324                dsname        = upcase(scan(filename, 1, '.'));
325                standard_name = upcase(scan(dsname,  -1, '_'));
326                needs_rename  = (dsname ne standard_name);
327                xpt_in_path   = "&indir\" || strip(filename);
328                xpt_out_path  = "&outdir\DAC_XPT\" ||
329                                strip(lowcase(standard_name)) || '.xpt';
330            run;
331        
332            filename _xptlst clear;
333        
334            proc sql noprint;
335                select count(*) into :xpt_total        trimmed from _work_xpt;
336                select count(*) into :xpt_rename_count trimmed from _work_xpt
337                    where needs_rename = 1;
338            quit;
339        
340            %put NOTE: Found &xpt_total XPT file(s), &xpt_rename_count require renaming.;
341        
342            %if &xpt_total > 0 and &xpt_rename_count > 0 %then %do;
343        
344                /* Check for duplicate standard names and warn/exclude */
345                proc sql noprint;
346                    create table _work_xpt_dups as
347                    select standard_name, count(*) as n
348                    from _work_xpt
349                    group by standard_name
350                    having count(*) > 1;
351                    select count(*) into :xpt_dup_count trimmed from _work_xpt_dups;
352                quit;
353        
354                %if &xpt_dup_count > 0 %then %do;
8                                           The SAS System                  15:33 Monday, May 18, 2026

355                    %put WARNING: Multiple XPT datasets map to the same standard name.;
356                    %put WARNING: The following XPT datasets will be SKIPPED:;
357                    data _null_;
358                        set _work_xpt_dups;
359                        put "  Standard name '" standard_name +(-1)
360                            "' has " n "conflicting source datasets.";
361                    run;
362                    proc sql noprint;
363                        delete from _work_xpt
364                        where standard_name in (select standard_name from _work_xpt_dups);
365                    quit;
366                    proc sql noprint;
367                        select count(*) into :xpt_total        trimmed from _work_xpt;
368                        select count(*) into :xpt_rename_count trimmed from _work_xpt
369                            where needs_rename = 1;
370                    quit;
371                %end;
372        
373                proc datasets lib=work nolist; delete _work_xpt_dups; quit;
374        
375                %if &xpt_rename_count > 0 %then %do;
376        
377                    /* Create DAC_XPT output directory if needed */
378                    %let dac_xpt_dir   = &outdir\DAC_XPT;
379                    %let dac_xpt_exist = %sysfunc(fileexist(&dac_xpt_dir));
380        
381                    %if &dac_xpt_exist = 0 %then %do;
382                        %put NOTE: Creating directory &dac_xpt_dir;
383                        %let _rc = %sysfunc(dcreate(DAC_XPT, &outdir));
384                        %if &_rc = %then %do;
385                            %put ERROR: Failed to create directory &dac_xpt_dir;
386                            %abort;
387                        %end;
388                    %end;
389                    %else %do;
390                        %put NOTE: Directory &dac_xpt_dir already exists.;
391                    %end;
392        
393                    /* Generate a call to %_copy_xpt_file for each XPT file.
394                       Using %nrstr prevents premature macro resolution of the
395                       parameter values inside the DATA step. */
396                    data _null_;
397                        set _work_xpt;
398                        call execute(
399                            '%_copy_xpt_file(inpath=' || strip(xpt_in_path)   ||
400                            ', outpath='              || strip(xpt_out_path)  ||
401                            ', standard_name='        || strip(standard_name) || ')'
402                        );
403                    run;
404        
405                    %put NOTE: XPT dataset standardization complete.;
406                    %put NOTE: Standardized XPT files are in: &dac_xpt_dir;
407        
408                %end; /* xpt_rename_count > 0 after dedup */
9                                           The SAS System                  15:33 Monday, May 18, 2026

409        
410            %end; /* xpt_total > 0 and xpt_rename_count > 0 */
411            %else %if &xpt_total > 0 %then %do;
412                %put NOTE: All &xpt_total XPT file(s) already have standard names. No DAC_XPT
412      ! folder created.;
413            %end;
414        
415            proc datasets lib=work nolist; delete _work_xpt; quit;
416        
417            %put NOTE: [rename_study_domains] Processing complete.;
418        
419        %mend rename_study_domains;
420        
421        %rename_study_domains;
