1          /*------------------------------------------------------------------*
2          | PROGRAM NAME : rename_study_domains_cli20260320.sas
3          | SHORT DESC   : Standardizes SAS and XPT dataset names by removing
4          |                suffixes (e.g., AE_PLACEBO to AE) and placing
5          |                renamed copies in DAC_SAS or DAC_XPT subfolders
6          *------------------------------------------------------------------*
7          | CREATED BY   : DAC Development Team
8          | DATE CREATED : 2026-05-08
9          | VERSION      : 1.2
10         *------------------------------------------------------------------*
11         | VERSION UPDATES:
12         | 2026-05-08: Initial CLI release (v1.0)
13         |   - Added SYSPARM parsing for input and output directories
14         |   - Standardizes dataset names by keeping only the prefix before
15         |     the first underscore (e.g., AE_PLACEBO -> AE)
16         |   - Copies SAS7BDAT datasets to DAC_SAS subfolder when any file
17         |     in the input directory has a non-standard (suffixed) name
18         |   - Copies XPT datasets to DAC_XPT subfolder when any XPT file
19         |     in the input directory has a non-standard name
20         |   - Files without underscores are copied unchanged to the new
21         |     folder so the folder is a complete, self-consistent set
22         | 2026-05-12: SAS7BDAT logic updated to match OriginalSAS (v1.1)
23         |   - Replaced Windows DIR-based file listing with libname +
24         |     dictionary.tables discovery (aligns with
25         |     rename_study_domains_ZRlocalCopy.sas)
26         |   - ALL datasets are now copied to DAC_SAS first via proc copy,
27         |     then datasets with suffixes are renamed in-place in DAC_SAS
28         |     using proc datasets change (same approach as original script)
29         |   - Standard name derived with scan(memname, 1, '_') -- identical
30         |     to the original script
31         | 2026-05-12: Fix standard name extraction (v1.2)
32         |   - Changed scan position from 1 to -1 so the domain name is taken
2                                           The SAS System                  15:33 Monday, May 18, 2026

33         |     from the LAST token after the final underscore (e.g.
34         |     BERKELEY_AE -> AE).  Using position 1 caused all datasets to
35         |     map to the study prefix (e.g. BERKELEY), triggering a duplicate-
36         |     name collision for every dataset in the library.
37         *------------------------------------------------------------------*
38         | PURPOSE
39         | Checks SAS (.sas7bdat) and XPT (.xpt) datasets in the specified
40         | input directory and standardizes their names by removing
41         | study-specific suffixes (e.g., converting AE_PLACEBO to AE).
42         | When any dataset requires renaming, ALL datasets of that type are
43         | copied with standardized names to a new subfolder:
44         |   - DAC_SAS for .sas7bdat files
45         |   - DAC_XPT for .xpt files
46         | This ensures that subsequent pipeline scripts operate on a
47         | complete, consistently named set of datasets.
48         |
49         | Naming rule: the standard name is the portion of the dataset name
50         | after the last underscore (scan(memname, -1, '_')).  E.g.:
51         |   BERKELEY_AE   -> AE
52         |   BERKELEY_SUPPAE -> SUPPAE
53         |   CM          -> CM  (unchanged; no folder created for this alone)
54         |
55         | 1.1: REQUIRED SYSPARM PARAMETERS (pipe-delimited)
56         | INPUT_DIRECTORY  = Path to folder containing .sas7bdat or .xpt
57         |                    files to be renamed
58         | OUTPUT_DIRECTORY = Path to folder where DAC_SAS and/or DAC_XPT
59         |                    subfolders will be created. Must exist prior
60         |                    to execution.
61         |
62         | USAGE:
63         |   sas -sysparm "input_directory|output_directory"
64         |       -sysin rename_study_domains_cli20260320.sas
65         |
66         | OUTPUT STRUCTURE:
67         |   output_directory\
68         |   ├── DAC_SAS\    - Standardized SAS7BDAT datasets
69         |   │                 (created only when any .sas7bdat dataset has
70         |   │                  a non-standard suffix)
71         |   └── DAC_XPT\   - Standardized XPT datasets
72         |                     (created only when any .xpt file has
73         |                      a non-standard suffix)
74         *------------------------------------------------------------------*
75         | OPERATING SYSTEM COMPATIBILITY
76         | SAS v9.4 or Higher: Yes
77         | Windows:            Yes
78         *------------------------------------------------------------------*
79         | NOTES
80         | - If two input datasets share the same standard name (e.g.,
81         |   AE_PLACEBO and AE_TREATMENT both map to AE), a WARNING is
82         |   issued and those datasets are skipped.  Resolve naming conflicts
83         |   in the source data before running the pipeline.
84         | - For XPT files the script queries the SAS transport library to
85         |   obtain the actual member name inside each file.  SAS XPT
86         |   format limits member names to 8 characters.
3                                           The SAS System                  15:33 Monday, May 18, 2026

87         *------------------------------------------------------------------*
88         | EXAMPLES
89         |
90         | Standardize SAS dataset names:
91         |   sas -sysparm "C:\data\input|C:\data\output"
92         |       -sysin rename_study_domains_cli20260320.sas
93         |
94         | Standardize XPT dataset names:
95         |   sas -sysparm "C:\data\xpt_files|C:\data\output"
96         |       -sysin rename_study_domains_cli20260320.sas
97         *------------------------------------------------------------------*/
98         
99         /* ----------------------------------------------------------------
100           Helper macro: copy one XPT file to DAC_XPT with a standardized
101           member name.  Called via %nrstr() inside a DATA step CALL EXECUTE
102           so that each file is processed sequentially after the driving
103           DATA step completes.
104        
105           Parameters:
106             inpath        - full path to the source .xpt file
107             outpath       - full path for the destination .xpt file
108             standard_name - desired (standardized) SAS dataset name
109        ---------------------------------------------------------------- */
110        %macro _copy_xpt_file(inpath=, outpath=, standard_name=);
111        
112            /* Open source XPT with SAS transport engine */
113            libname _xinlib xport "&inpath";
114        
115            /* Get the actual member name stored inside the XPT file */
116            proc sql noprint;
117                select memname into :_xpt_memname trimmed
118                from dictionary.tables
119                where libname = '_XINLIB';
120            quit;
121        
122            %if %length(&_xpt_memname) = 0 %then %do;
123                %put WARNING: No dataset found in XPT file: &inpath -- skipping.;
124                libname _xinlib clear;
125                %return;
126            %end;
127        
128            %let _xpt_memname_lc = %lowcase(&_xpt_memname);
129            %let _std_lc         = %lowcase(&standard_name);
130        
131            %if %upcase(&_xpt_memname) ne %upcase(&standard_name) %then %do;
132                /* Copy internal dataset to WORK under the standard name */
133                data work.&_std_lc;
134                    set _xinlib.&_xpt_memname_lc;
135                run;
136        
137                libname _xinlib clear;
138        
139                /* Write the WORK dataset to the new XPT file */
140                libname _xoutlib xport "&outpath";
4                                           The SAS System                  15:33 Monday, May 18, 2026

141                proc copy in=work out=_xoutlib;
142                    select &_std_lc;
143                run;
144                libname _xoutlib clear;
145        
146                /* Clean up temporary WORK dataset */
147                proc datasets lib=work nolist;
148                    delete &_std_lc;
149                quit;
150            %end;
151            %else %do;
152                /* Name already matches standard; copy file as-is */
153                libname _xoutlib xport "&outpath";
154                proc copy in=_xinlib out=_xoutlib; run;
155                libname _xinlib  clear;
156                libname _xoutlib clear;
157            %end;
158        
159        %mend _copy_xpt_file;
